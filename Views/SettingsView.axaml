<UserControl xmlns="https://github.com/avaloniaui"
			 xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
			 xmlns:vm="using:NyxAssetsEditor.ViewModels"
			 x:Class="NyxAssetsEditor.Views.SettingsView"
			 x:DataType="vm:SettingsViewModel">
	<StackPanel Margin="30" Spacing="15">
		<TextBlock Text="{Binding Title}" FontSize="28" FontWeight="Bold" Foreground="#FF6B6B"/>
		<TextBlock Text="{Binding Description}" FontSize="14" Foreground="#888888" TextWrapping="Wrap"/>
		
		<!-- General Section -->
		<Border Background="#1E1E1E" CornerRadius="8" Padding="20" Margin="0,10,0,0">
			<StackPanel Spacing="15">
				<TextBlock Text="Editor General" FontSize="18" FontWeight="SemiBold" Foreground="#FFFFFF"/>
				<CheckBox Content="Enable Hardware Acceleration" IsChecked="True"/>
				<CheckBox Content="Auto-save Project Changes" IsChecked="True"/>
			</StackPanel>
		</Border>

		<!-- Sprites Panel Section -->
		<Border Background="#1E1E1E" CornerRadius="8" Padding="20" Margin="0,10,0,0">
			<StackPanel Spacing="15">
				<TextBlock Text="Sprites Panel" FontSize="18" FontWeight="SemiBold" Foreground="#FFFFFF"/>
				<StackPanel Orientation="Horizontal" Spacing="10">
					<TextBlock Text="Default Page Size:" VerticalAlignment="Center" Foreground="#CCCCCC"/>
					<ComboBox SelectedIndex="{Binding SelectedPageSizeIndex}" Width="100">
						<ComboBoxItem Content="50"/>
						<ComboBoxItem Content="100"/>
						<ComboBoxItem Content="200"/>
					</ComboBox>
				</StackPanel>
			</StackPanel>
		</Border>
	</StackPanel>
</UserControl>
