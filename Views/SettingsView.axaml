<UserControl xmlns="https://github.com/avaloniaui"
			 xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
			 xmlns:vm="using:NyxAssetsEditor.ViewModels"
			 x:Class="NyxAssetsEditor.Views.SettingsView"
			 x:DataType="vm:SettingsViewModel">
	<ScrollViewer>
		<StackPanel Margin="30" Spacing="15">
			<TextBlock Text="{Binding Title}" FontSize="28" FontWeight="Bold" Foreground="#FF6B6B"/>
			<TextBlock Text="{Binding Description}" FontSize="14" Foreground="#888888" TextWrapping="Wrap"/>

			<!-- Sprites Panel Section -->
			<Border Background="#1E1E1E" CornerRadius="8" Padding="20" Margin="0,10,0,0">
				<StackPanel Spacing="15">
					<TextBlock Text="Sprites Panel" FontSize="18" FontWeight="SemiBold" Foreground="#FFFFFF"/>
					<StackPanel Orientation="Horizontal" Spacing="10" VerticalAlignment="Center">
						<TextBlock Text="Default Page Size:" VerticalAlignment="Center" Foreground="#CCCCCC" Width="160"/>
						<ComboBox SelectedIndex="{Binding SelectedPageSizeIndex}" Width="100">
							<ComboBoxItem Content="50"/>
							<ComboBoxItem Content="100"/>
							<ComboBoxItem Content="200"/>
						</ComboBox>
						<TextBlock Text="Number of sprites shown per page in the viewer."
								   FontStyle="Italic" FontSize="11" Foreground="#666666"
								   VerticalAlignment="Center" Margin="8,0,0,0"/>
					</StackPanel>
				</StackPanel>
			</Border>

			<!-- Things Panel Section -->
			<Border Background="#1E1E1E" CornerRadius="8" Padding="20" Margin="0,10,0,0">
				<StackPanel Spacing="15">
					<TextBlock Text="Things Panel" FontSize="18" FontWeight="SemiBold" Foreground="#FFFFFF"/>

					<StackPanel Orientation="Horizontal" Spacing="10" VerticalAlignment="Center">
						<TextBlock Text="Client Version:" VerticalAlignment="Center" Foreground="#CCCCCC" Width="160"/>
						<ComboBox SelectedIndex="{Binding SelectedVersionIndex}" Width="120" Height="28">
							<ComboBoxItem Content="10.98"/>
							<ComboBoxItem Content="8.60"/>
							<ComboBoxItem Content="7.60"/>
						</ComboBox>
						<TextBlock Text="Affects .dat binary format parsing rules and checkbox defaults."
								   FontStyle="Italic" FontSize="11" Foreground="#666666"
								   VerticalAlignment="Center" Margin="8,0,0,0"/>
					</StackPanel>

					<StackPanel Orientation="Horizontal" Spacing="10" VerticalAlignment="Center">
						<TextBlock Text="Thing ID Offset:" VerticalAlignment="Center" Foreground="#CCCCCC" Width="160"/>
						<NumericUpDown Value="{Binding SelectedThingIdOffset}" Minimum="0" Maximum="10000" Increment="1" Width="120" Height="28" Padding="5,0"/>
						<TextBlock Text="Added to raw catalog indices when displaying IDs. Keep at 0 to match NyxAssets loader."
								   FontStyle="Italic" FontSize="11" Foreground="#666666"
								   VerticalAlignment="Center" Margin="8,0,0,0" TextWrapping="Wrap" MaxWidth="320"/>
					</StackPanel>
				</StackPanel>
			</Border>
		</StackPanel>
	</ScrollViewer>
</UserControl>

