<UserControl xmlns="https://github.com/avaloniaui"
			 xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
			 xmlns:vm="using:NyxAssetsEditor.ViewModels.ArchiveLoaders"
			 xmlns:sprites="using:NyxAssetsEditor.ViewModels.Sprites"
			 x:Class="NyxAssetsEditor.Views.ArchiveLoaders.FloatingSpriteLoaderControl"
			 x:DataType="vm:FloatingSpriteLoaderViewModel"
			 Width="{Binding DisplayWidth}"
			 Focusable="True">

	<UserControl.KeyBindings>
		<KeyBinding Gesture="Ctrl+C" Command="{Binding CopySelectedSpriteCommand}"/>
		<KeyBinding Gesture="Ctrl+V" Command="{Binding PasteSelectedSpriteCommand}"/>
		<KeyBinding Gesture="Delete" Command="{Binding RemoveSelectedSpritesCommand}"/>
		<KeyBinding Gesture="Ctrl+Z" Command="{Binding UndoCommand}"/>
		<KeyBinding Gesture="Ctrl+Y" Command="{Binding RedoCommand}"/>
	</UserControl.KeyBindings>

	<UserControl.Styles>
		<Style Selector="Border.sprite-tile">
			<Setter Property="BorderBrush" Value="#353535"/>
			<Setter Property="BorderThickness" Value="1"/>
		</Style>
		<Style Selector="Border.sprite-tile.selected">
			<Setter Property="BorderBrush" Value="#3A7BD5"/>
			<Setter Property="BorderThickness" Value="2"/>
		</Style>
		<Style Selector="Border.sprite-list-row">
			<Setter Property="Background" Value="Transparent"/>
		</Style>
		<Style Selector="Border.sprite-list-row.selected">
			<Setter Property="Background" Value="#223A7BD5"/>
		</Style>
	</UserControl.Styles>

	<Border Background="#252525" BorderBrush="#3C3C3C" BorderThickness="1" CornerRadius="8" BoxShadow="0 4 12 0 #7F000000">
		<Grid RowDefinitions="Auto, *, Auto">
			<!-- Title Bar (Draggable) -->
			<Border Grid.Row="0" Name="TitleBar" Background="#2D2D2D" Height="36" Padding="12,0,6,0">
				<Border.ContextMenu>
					<ContextMenu>
						<MenuItem Header="Undock" Command="{Binding UndockCommand}" IsVisible="{Binding !IsFloating}"/>
						<MenuItem Header="Dock Left" Command="{Binding SetDockStateCommand}" CommandParameter="Left" IsVisible="{Binding IsFloating}"/>
						<MenuItem Header="Dock Center" Command="{Binding SetDockStateCommand}" CommandParameter="Center" IsVisible="{Binding IsFloating}"/>
						<MenuItem Header="Dock Right" Command="{Binding SetDockStateCommand}" CommandParameter="Right" IsVisible="{Binding IsFloating}"/>
						<Separator/>
						<MenuItem Header="Close" Command="{Binding ClosePanelCommand}"/>
					</ContextMenu>
				</Border.ContextMenu>
				<Grid ColumnDefinitions="*, Auto, Auto, Auto, Auto, Auto, Auto, Auto">
					<!-- Panel Name -->
					<StackPanel Orientation="Horizontal" Grid.Column="0" Spacing="8" VerticalAlignment="Center">
						<TextBlock Text="Sprites Viewer" FontWeight="SemiBold" Foreground="#E0E0E0" FontSize="13"/>
						<TextBlock Text="{Binding FileName, Mode=OneWay}" ToolTip.Tip="{Binding FilePath, Mode=OneWay}" FontSize="11" Foreground="#888888" VerticalAlignment="Center" TextTrimming="CharacterEllipsis"/>
					</StackPanel>
					
					<!-- Page Size Dropdown -->
					<StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center" Margin="0,0,8,0" Spacing="4" IsVisible="{Binding IsArchiveLoaded}">
						<TextBlock Text="Page size:" FontSize="10" Foreground="#888888" VerticalAlignment="Center"/>
						<ComboBox ItemsSource="{Binding AvailablePageSizes}" SelectedItem="{Binding PageSize}" FontSize="10" Height="22" Padding="6,2" BorderThickness="0" Background="#1E1E1E" CornerRadius="4"/>
					</StackPanel>

					<!-- Options Dropdown Button -->
					<Button Grid.Column="2" Width="28" Height="24" Background="Transparent" BorderThickness="0" CornerRadius="4" Margin="0,0,4,0" IsVisible="{Binding IsArchiveLoaded}" ToolTip.Tip="Options">
						<Image Source="/Assets/Icons/action_dots.png" Width="12" Height="12"/>
						<Button.Flyout>
							<MenuFlyout Placement="BottomEdgeAlignedRight">
								<MenuItem Header="Save spr/assets" Command="{Binding RequestSaveConfirmationCommand}"/>
								<MenuItem Header="Save As..." Command="{Binding SaveAsCommand}"/>
							</MenuFlyout>
						</Button.Flyout>
					</Button>
					
					<!-- List/Grid Switcher Button -->
					<Button Grid.Column="3" Command="{Binding ToggleViewModeCommand}" Width="28" Height="24" Background="Transparent" BorderThickness="0" CornerRadius="4" Margin="0,0,4,0" IsVisible="{Binding IsArchiveLoaded}" ToolTip.Tip="Toggle List/Grid View">
						<Panel>
							<!-- List Icon (Visible when GridView is active, because clicking toggles to List) -->
							<Image Source="/Assets/Icons/action_layout_list.png" Width="14" Height="14" IsVisible="{Binding IsGridView}"/>
							<!-- Grid Icon (Visible when ListView is active, because clicking toggles to Grid) -->
							<Image Source="/Assets/Icons/action_layout_grid.png" Width="14" Height="14" IsVisible="{Binding IsListView}"/>
						</Panel>
					</Button>

					<!-- Undo Button -->
					<Button Grid.Column="4" Command="{Binding UndoCommand}" Width="28" Height="24" Background="Transparent" BorderThickness="0" CornerRadius="4" Margin="0,0,4,0" IsVisible="{Binding IsArchiveLoaded}" ToolTip.Tip="Undo (Ctrl+Z)">
						<Image Source="/Assets/Icons/action_undo.png" Width="14" Height="14"/>
					</Button>

					<!-- Redo Button -->
					<Button Grid.Column="5" Command="{Binding RedoCommand}" Width="28" Height="24" Background="Transparent" BorderThickness="0" CornerRadius="4" Margin="0,0,4,0" IsVisible="{Binding IsArchiveLoaded}" ToolTip.Tip="Redo (Ctrl+Y)">
						<Image Source="/Assets/Icons/action_redo.png" Width="14" Height="14"/>
					</Button>
					
					<!-- Minimize Button -->
					<Button Grid.Column="6" Command="{Binding ToggleMinimizeCommand}" Width="28" Height="24" Background="Transparent" BorderThickness="0" CornerRadius="4" Margin="0,0,4,0" ToolTip.Tip="Minimize">
						<Image Source="/Assets/Icons/action_minimize.png" Width="14" Height="14"/>
					</Button>
					
					<!-- Close Button -->
					<Button Grid.Column="7" Command="{Binding ClosePanelCommand}" Width="28" Height="24" Background="Transparent" BorderThickness="0" CornerRadius="4" ToolTip.Tip="Close">
						<Image Source="/Assets/Icons/action_close.png" Width="14" Height="14"/>
					</Button>
				</Grid>
			</Border>

			<Grid Grid.Row="1" IsVisible="{Binding !IsMinimized}" Background="#1E1E1E" Height="{Binding DisplayHeight}"
				  DragDrop.AllowDrop="True"
				  DragDrop.DragOver="OnDragOver"
				  DragDrop.Drop="OnDrop">
				<!-- Grid View Mode -->
				<ListBox x:Name="SpriteGridListBox" ItemsSource="{Binding PagedSprites, Mode=OneWay}" IsVisible="{Binding IsGridView, Mode=OneWay}" Background="Transparent" BorderThickness="0" ScrollViewer.HorizontalScrollBarVisibility="Disabled" Padding="8" SelectionMode="Multiple">
					<ListBox.ItemsPanel>
						<ItemsPanelTemplate>
							<WrapPanel Orientation="Horizontal" HorizontalAlignment="Center"/>
						</ItemsPanelTemplate>
					</ListBox.ItemsPanel>
					<ListBox.Styles>
						<Style Selector="ListBoxItem" x:DataType="sprites:SpriteViewModel">
							<Setter Property="IsSelected" Value="{Binding IsSelected, Mode=TwoWay}"/>
						</Style>
					</ListBox.Styles>
					<ListBox.ItemTemplate>
						<DataTemplate x:DataType="sprites:SpriteViewModel" x:CompileBindings="False">
							<Border Classes="sprite-tile" Classes.selected="{Binding IsSelected, Mode=OneWay}" Background="#2A2A2A" CornerRadius="6" Padding="8" Margin="4" Width="{Binding $parent[UserControl].DataContext.GridTileWidth}" Height="{Binding $parent[UserControl].DataContext.GridTileHeight}"
									PointerPressed="OnSpritePointerPressed">
								<Border.ContextMenu>
									<ContextMenu>
										<MenuItem Header="Edit in Paint" Command="{Binding EditInPaintCommand}"/>
										<Separator/>
										<MenuItem Header="Copy" Command="{Binding CopyCommand}" InputGesture="Ctrl+C"/>
										<MenuItem Header="Paste" Command="{Binding PasteCommand}" InputGesture="Ctrl+V"/>
										<Separator/>
										<MenuItem Header="Import..." Command="{Binding ReplaceCommand}"/>
										<MenuItem Header="Export">
											<MenuItem Header="PNG" Command="{Binding ExportPngCommand}"/>
											<MenuItem Header="JPEG" Command="{Binding ExportJpegCommand}"/>
											<MenuItem Header="BMP" Command="{Binding ExportBmpCommand}"/>
										</MenuItem>
										<Separator/>
										<MenuItem Header="Remove" Command="{Binding RemoveCommand}"/>
									</ContextMenu>
								</Border.ContextMenu>
								<StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
									<Image Source="{Binding Preview, Mode=OneWay}" Width="{Binding $parent[UserControl].DataContext.AssetDisplaySize}" Height="{Binding $parent[UserControl].DataContext.AssetDisplaySize}" RenderOptions.BitmapInterpolationMode="None" HorizontalAlignment="Center" VerticalAlignment="Center"/>
									<TextBlock Text="{Binding Id, Mode=OneWay}" FontSize="10" Foreground="#888888" HorizontalAlignment="Center" Margin="0,6,0,0"/>
								</StackPanel>
							</Border>
						</DataTemplate>
					</ListBox.ItemTemplate>
				</ListBox>

				<!-- List View Mode -->
				<ListBox x:Name="SpriteListListBox" ItemsSource="{Binding PagedSprites, Mode=OneWay}" IsVisible="{Binding IsListView, Mode=OneWay}" Background="Transparent" BorderThickness="0" Padding="0" SelectionMode="Multiple">
					<ListBox.ItemsPanel>
						<ItemsPanelTemplate>
							<VirtualizingStackPanel/>
						</ItemsPanelTemplate>
					</ListBox.ItemsPanel>
					<ListBox.Styles>
						<Style Selector="ListBoxItem" x:DataType="sprites:SpriteViewModel">
							<Setter Property="Padding" Value="0"/>
							<Setter Property="MinHeight" Value="42"/>
							<Setter Property="Background" Value="Transparent"/>
							<Setter Property="IsSelected" Value="{Binding IsSelected, Mode=TwoWay}"/>
						</Style>
					</ListBox.Styles>
					<ListBox.ItemTemplate>
						<DataTemplate x:DataType="sprites:SpriteViewModel" x:CompileBindings="False">
							<Border Classes="sprite-list-row" Classes.selected="{Binding IsSelected, Mode=OneWay}" BorderBrush="#2D2D2D" BorderThickness="0,0,0,1" Padding="8,3" PointerPressed="OnSpritePointerPressed">
								<Border.ContextMenu>
									<ContextMenu>
										<MenuItem Header="Edit in Paint" Command="{Binding EditInPaintCommand}"/>
										<Separator/>
										<MenuItem Header="Copy" Command="{Binding CopyCommand}" InputGesture="Ctrl+C"/>
										<MenuItem Header="Paste" Command="{Binding PasteCommand}" InputGesture="Ctrl+V"/>
										<Separator/>
										<MenuItem Header="Import..." Command="{Binding ReplaceCommand}"/>
										<MenuItem Header="Export">
											<MenuItem Header="PNG" Command="{Binding ExportPngCommand}"/>
											<MenuItem Header="JPEG" Command="{Binding ExportJpegCommand}"/>
											<MenuItem Header="BMP" Command="{Binding ExportBmpCommand}"/>
										</MenuItem>
										<Separator/>
										<MenuItem Header="Remove" Command="{Binding RemoveCommand}"/>
									</ContextMenu>
								</Border.ContextMenu>
								<Grid ColumnDefinitions="Auto, *">
									<!-- Square Image Container -->
									<Border Grid.Column="0" Width="{Binding $parent[UserControl].DataContext.ListBorderWidthHeight}" Height="{Binding $parent[UserControl].DataContext.ListBorderWidthHeight}" Background="#1D1D1D" BorderBrush="#4A4A4A" BorderThickness="1" CornerRadius="4">
										<Image Source="{Binding Preview, Mode=OneWay}" Width="{Binding $parent[UserControl].DataContext.AssetDisplaySize}" Height="{Binding $parent[UserControl].DataContext.AssetDisplaySize}" Stretch="Uniform" RenderOptions.BitmapInterpolationMode="None"/>
									</Border>
									
									<!-- ID Text -->
									<TextBlock Grid.Column="1" Text="{Binding Id, Mode=OneWay}" VerticalAlignment="Center" Margin="12,0,0,0" Foreground="#E0E0E0" FontSize="13" FontWeight="SemiBold"/>
								</Grid>
							</Border>
						</DataTemplate>
					</ListBox.ItemTemplate>
				</ListBox>
				
				<StackPanel IsVisible="{Binding !IsArchiveLoaded}" VerticalAlignment="Center" HorizontalAlignment="Center" Spacing="12">
					<!-- Unsupported Version Error State -->
					<Border IsVisible="{Binding HasError}"
							Background="#331A1A"
							BorderBrush="#FF5E5E"
							BorderThickness="1.5"
							CornerRadius="8"
							Padding="18"
							Width="340"
							Cursor="Hand"
							PointerPressed="OnEmptyStateClick">
						<StackPanel Spacing="10" HorizontalAlignment="Center" VerticalAlignment="Center">
							<Image Source="/Assets/Icons/state/warning.png" Width="24" Height="24" HorizontalAlignment="Center"/>
							<TextBlock Text="Unsupported version" FontWeight="Bold" Foreground="#FF5E5E" FontSize="14" HorizontalAlignment="Center"/>
							<TextBlock Text="{Binding ErrorMessage}" Foreground="#FF8888" FontSize="12" TextWrapping="Wrap" TextAlignment="Center" HorizontalAlignment="Center"/>
							<TextBlock Text="Click to try another file" Foreground="#888888" FontSize="10" HorizontalAlignment="Center" Margin="0,5,0,0"/>
						</StackPanel>
					</Border>

					<Border Name="EmptyStateDropzone"
							IsVisible="{Binding !HasError}"
							Background="#22000000"
							BorderBrush="#3A7BD5"
							BorderThickness="1.5"
							CornerRadius="8"
							Padding="18"
							Width="340"
							Cursor="Hand"
							PointerPressed="OnEmptyStateClick">
						<StackPanel Spacing="10" HorizontalAlignment="Center" VerticalAlignment="Center">
							<Image Source="/Assets/Icons/state/sprites_stack.png" Width="24" Height="24" HorizontalAlignment="Center"/>
							<TextBlock Text="Click to Load Assets" FontWeight="SemiBold" Foreground="#3A7BD5" FontSize="13" HorizontalAlignment="Center"/>
							<TextBlock Text="Supports .spr and .assets archives" Foreground="#666666" FontSize="10" TextWrapping="Wrap" TextAlignment="Center" HorizontalAlignment="Center"/>
						</StackPanel>
					</Border>
					
					<!-- Loading Settings Container -->
					<Border Background="#252525" BorderBrush="#353535" BorderThickness="1" CornerRadius="6" Padding="12" Width="340">
						<StackPanel Spacing="8">
							<TextBlock Text="Loading Settings" FontSize="11" FontWeight="SemiBold" Foreground="#888888" Margin="0,0,0,4"/>
							<CheckBox Content="Prefer settings from .otfi" IsChecked="{Binding PreferOtfiSettings}" FontSize="11" Height="20"
									  ToolTip.Tip="Uses explicit settings from a matching .otfi file. If the file is missing or incomplete, loading reverts to recommended settings."/>
							<CheckBox Content="Guess settings based on signature" IsChecked="{Binding GuessSettingsFromSignature}" FontSize="11" Height="20"
									  ToolTip.Tip="Uses recommended settings detected from the archive version. Transparency cannot be detected and may need to be enabled manually. Enabling this disables OTFI preference."/>
							<TextBlock Text="Format settings" Foreground="#777777" FontSize="10" Margin="0,3,0,0"/>
							<CheckBox Content="Transparent Pixels" IsChecked="{Binding UseTransparentPixels}" IsEnabled="{Binding CanEditTransparency}" FontSize="11" Height="20"
									  ToolTip.Tip="Transparency is not detectable from the archive version. Set it manually unless OTFI settings are active."/>
							<CheckBox Content="Extended Sprite IDs" IsChecked="{Binding UseExtendedSpriteIds}" IsEnabled="{Binding CanEditManualSettings}" FontSize="11" Height="20"/>
						</StackPanel>
					</Border>
				</StackPanel>
				<Border IsVisible="{Binding HasError}" VerticalAlignment="Top" Margin="8" Padding="8,5"
						Background="#CC4A3518" BorderBrush="#D99A3E" BorderThickness="1" CornerRadius="4" ZIndex="20">
					<TextBlock Text="{Binding ErrorMessage}" Foreground="#FFD18A" FontSize="11" TextWrapping="Wrap"/>
				</Border>
			</Grid>

			<!-- Footer: sprite actions + pagination -->
			<Border Grid.Row="2" Name="BottomBar" IsVisible="{Binding !IsMinimized}" Background="#2D2D2D" BorderBrush="#3C3C3C" BorderThickness="0,1,0,0" Padding="8,6">
				<StackPanel Spacing="6">
					<Grid ColumnDefinitions="*, *, *" IsVisible="{Binding IsArchiveLoaded}">
						<!-- Left: New button and separator -->
						<StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="6" HorizontalAlignment="Left">
							<Button Command="{Binding NewSpriteCommand}" ToolTip.Tip="New Sprite" Padding="8,4">
								<Image Source="/Assets/Icons/action_new.png" Width="14" Height="14"/>
							</Button>
							<Border Width="1" Height="20" Background="#444444" Margin="2,0"/>
						</StackPanel>

						<!-- Center: Copy, Paste, Import, Export -->
						<StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="6" HorizontalAlignment="Center">
							<Border Background="Transparent" ToolTip.Tip="Copy">
								<Button Command="{Binding CopySelectedSpriteCommand}" Padding="8,4">
									<Image Source="/Assets/Icons/action_copy.png" Width="14" Height="14"/>
								</Button>
							</Border>
							<Border Background="Transparent" ToolTip.Tip="Paste">
								<Button Command="{Binding PasteSelectedSpriteCommand}" Padding="8,4">
									<Image Source="/Assets/Icons/action_paste.png" Width="14" Height="14"/>
								</Button>
							</Border>
							<Border Background="Transparent" ToolTip.Tip="Import">
								<Button Command="{Binding ImportSelectedSpritesCommand}" Padding="8,4">
									<Image Source="/Assets/Icons/action_import.png" Width="14" Height="14"/>
								</Button>
							</Border>
							<Button ToolTip.Tip="Export" Padding="8,4">
								<Image Source="/Assets/Icons/action_export.png" Width="14" Height="14"/>
								<Button.Flyout>
									<MenuFlyout Placement="Top">
										<MenuItem Header="PNG" Command="{Binding ExportSelectedPngCommand}"/>
										<MenuItem Header="JPEG" Command="{Binding ExportSelectedJpegCommand}"/>
										<MenuItem Header="BMP" Command="{Binding ExportSelectedBmpCommand}"/>
									</MenuFlyout>
								</Button.Flyout>
							</Button>
						</StackPanel>

						<!-- Right: Remove and selection count -->
						<StackPanel Grid.Column="2" Orientation="Horizontal" Spacing="6" HorizontalAlignment="Right">
							<TextBlock Text="{Binding SelectedSpriteCount, StringFormat='{}{0} selected'}" Foreground="#888888" FontSize="10" VerticalAlignment="Center" Margin="0,0,8,0" IsVisible="{Binding HasSpriteSelection}"/>
							<Border Background="Transparent" ToolTip.Tip="Remove">
								<Button Command="{Binding RemoveSelectedSpritesCommand}" Padding="8,4">
									<Image Source="/Assets/Icons/action_delete.png" Width="14" Height="14"/>
								</Button>
							</Border>
						</StackPanel>
					</Grid>

					<Grid ColumnDefinitions="Auto, Auto, *, Auto, Auto">
					<Button Grid.Column="0" Command="{Binding FirstPageCommand}" IsEnabled="{Binding HasPreviousPage}" Padding="8,4" Margin="0,0,4,0" ToolTip.Tip="First Page">
						<Image Source="/Assets/Icons/arrow_m_left2.png" Width="12" Height="12"/>
					</Button>
					<Button Grid.Column="1" Command="{Binding PreviousPageCommand}" IsEnabled="{Binding HasPreviousPage}" Padding="8,4" ToolTip.Tip="Previous Page">
						<Image Source="/Assets/Icons/arrow_m_left.png" Width="12" Height="12"/>
					</Button>
					
					<StackPanel Grid.Column="2" Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Center" Spacing="6">
						<TextBlock Text="Page" Foreground="#888888" FontSize="12" VerticalAlignment="Center"/>
						<TextBox Text="{Binding CurrentPage, Mode=TwoWay}" Width="38" Height="22" Padding="2,1" FontSize="11" HorizontalContentAlignment="Center" VerticalContentAlignment="Center" Background="#1E1E1E" BorderThickness="0" CornerRadius="4" Foreground="#E0E0E0"/>
						<TextBlock Text="of" Foreground="#888888" FontSize="12" VerticalAlignment="Center"/>
						<TextBlock Text="{Binding TotalPages}" FontWeight="Bold" Foreground="#E0E0E0" FontSize="12" VerticalAlignment="Center"/>
						<TextBlock Text="|" Foreground="#444444" FontSize="12" VerticalAlignment="Center" Margin="6,0,0,0"/>
						<TextBlock Text="ID" Foreground="#888888" FontSize="12" VerticalAlignment="Center"/>
						<TextBox Text="{Binding JumpToIdText, Mode=TwoWay}" Width="52" Height="22" Padding="2,1" FontSize="11" HorizontalContentAlignment="Center" VerticalContentAlignment="Center" Background="#1E1E1E" BorderThickness="0" CornerRadius="4" Foreground="#E0E0E0">
							<TextBox.KeyBindings>
								<KeyBinding Gesture="Enter" Command="{Binding GoToIdCommand}"/>
							</TextBox.KeyBindings>
						</TextBox>
						<Button Command="{Binding GoToIdCommand}" Content="Go" Padding="8,2" Height="22" FontSize="11" ToolTip.Tip="Jump to ID"/>
					</StackPanel>
					
					<Button Grid.Column="3" Command="{Binding NextPageCommand}" IsEnabled="{Binding HasNextPage}" Padding="8,4" Margin="0,0,4,0" ToolTip.Tip="Next Page">
						<Image Source="/Assets/Icons/arrow_m_right.png" Width="12" Height="12"/>
					</Button>
					<Button Grid.Column="4" Command="{Binding LastPageCommand}" IsEnabled="{Binding HasNextPage}" Padding="8,4" ToolTip.Tip="Last Page">
						<Image Source="/Assets/Icons/arrow_m_right2.png" Width="12" Height="12"/>
					</Button>
					</Grid>
				</StackPanel>
			</Border>

			<!-- Resize Handles (Overlay) -->
			<!-- Left edge resize handle -->
			<Border Grid.RowSpan="3" Name="ResizeLeft" Width="5" HorizontalAlignment="Left" Background="Transparent" Cursor="SizeWestEast" ZIndex="100"
			        IsVisible="{Binding ShowResizeHandles}"/>

			<!-- Right edge resize handle -->
			<Border Grid.RowSpan="3" Name="ResizeRight" Width="5" HorizontalAlignment="Right" Background="Transparent" Cursor="SizeWestEast" ZIndex="100"
					IsVisible="{Binding ShowResizeHandles}"/>
			
			<!-- Bottom edge resize handle -->
			<Border Grid.RowSpan="3" Name="ResizeBottom" Height="5" VerticalAlignment="Bottom" Background="Transparent" Cursor="SizeNorthSouth" ZIndex="100"
					IsVisible="{Binding ShowResizeHandles}"/>
			
			<!-- Bottom-right corner resize handle -->
			<Border Grid.RowSpan="3" Name="ResizeCorner" Width="10" Height="10" HorizontalAlignment="Right" VerticalAlignment="Bottom" Background="Transparent" Cursor="BottomRightCorner" ZIndex="100"
					IsVisible="{Binding ShowResizeHandles}"/>
			
			<!-- Bottom-left corner resize handle -->
			<Border Grid.RowSpan="3" Name="ResizeBottomLeft" Width="10" Height="10" HorizontalAlignment="Left" VerticalAlignment="Bottom" Background="Transparent" Cursor="BottomLeftCorner" ZIndex="100"
					IsVisible="{Binding ShowResizeHandles}"/>
			<Border Grid.RowSpan="3" Name="ResizeTop" Height="5" VerticalAlignment="Top" Background="Transparent" Cursor="SizeNorthSouth" ZIndex="100"
					IsVisible="{Binding ShowResizeHandles}"/>
			<Border Grid.RowSpan="3" Name="ResizeTopLeft" Width="10" Height="10" HorizontalAlignment="Left" VerticalAlignment="Top" Background="Transparent" Cursor="TopLeftCorner" ZIndex="100"
					IsVisible="{Binding ShowResizeHandles}"/>
			<Border Grid.RowSpan="3" Name="ResizeTopRight" Width="10" Height="10" HorizontalAlignment="Right" VerticalAlignment="Top" Background="Transparent" Cursor="TopRightCorner" ZIndex="100"
					IsVisible="{Binding ShowResizeHandles}"/>
			<!-- Save Confirmation Overlay -->
			<Border Grid.Row="0" Grid.RowSpan="3" Background="#B0000000" IsVisible="{Binding ShowSaveConfirmation}" CornerRadius="8">
				<Border Background="#2A2A2A" BorderBrush="#444444" BorderThickness="1" CornerRadius="8" Padding="16" Width="340" HorizontalAlignment="Center" VerticalAlignment="Center" BoxShadow="0 4 12 0 #7F000000">
					<StackPanel Spacing="12">
						<TextBlock Text="Save Changes?" FontWeight="Bold" Foreground="#FFFFFF" HorizontalAlignment="Center" FontSize="13"/>
						<TextBlock Text="Are you sure you want to save a backup (.bak) of this archive?" FontSize="11" Foreground="#CCCCCC" TextWrapping="Wrap" TextAlignment="Center"/>
						<Grid ColumnDefinitions="*, *" Margin="0,8,0,0">
							<Button Grid.Column="0" Content="Cancel" Command="{Binding CancelSaveCommand}" Margin="0,0,4,0" HorizontalAlignment="Stretch" HorizontalContentAlignment="Center" FontSize="11" Padding="0,6"/>
							<Button Grid.Column="1" Content="Confirm" Command="{Binding ConfirmSaveCommand}" Background="#3A7BD5" Foreground="White" Margin="4,0,0,0" HorizontalAlignment="Stretch" HorizontalContentAlignment="Center" FontSize="11" Padding="0,6"/>
						</Grid>
					</StackPanel>
				</Border>
			</Border>
		</Grid>
	</Border>
</UserControl>
