<UserControl xmlns="https://github.com/avaloniaui"
			 xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
			 xmlns:vm="using:NyxAssetsEditor.ViewModels.ArchiveLoaders"
			 xmlns:sprites="using:NyxAssetsEditor.ViewModels.Sprites"
			 x:Class="NyxAssetsEditor.Views.ArchiveLoaders.FloatingSpriteLoaderControl"
			 x:DataType="vm:FloatingSpriteLoaderViewModel"
			 Width="{Binding DisplayWidth}"
			 Focusable="True">

	<UserControl.KeyBindings>
		<KeyBinding Gesture="Ctrl+C" Command="{Binding CopySelectedSpriteCommand}"/>
		<KeyBinding Gesture="Ctrl+V" Command="{Binding PasteSelectedSpriteCommand}"/>
	</UserControl.KeyBindings>

	<UserControl.Styles>
		<Style Selector="Border.sprite-tile">
			<Setter Property="BorderBrush" Value="#353535"/>
			<Setter Property="BorderThickness" Value="1"/>
		</Style>
		<Style Selector="Border.sprite-tile.selected">
			<Setter Property="BorderBrush" Value="#3A7BD5"/>
			<Setter Property="BorderThickness" Value="2"/>
		</Style>
		<Style Selector="Border.sprite-list-row">
			<Setter Property="Background" Value="Transparent"/>
		</Style>
		<Style Selector="Border.sprite-list-row.selected">
			<Setter Property="Background" Value="#223A7BD5"/>
		</Style>
	</UserControl.Styles>

	<Border Background="#252525" BorderBrush="#3C3C3C" BorderThickness="1" CornerRadius="8" BoxShadow="0 4 12 0 #7F000000">
		<Grid RowDefinitions="Auto, *, Auto">
			<!-- Title Bar (Draggable) -->
			<Border Grid.Row="0" Name="TitleBar" Background="#2D2D2D" Height="36" Padding="12,0,6,0">
				<Border.ContextMenu>
					<ContextMenu>
						<MenuItem Header="Undock" Command="{Binding UndockCommand}" IsVisible="{Binding !IsFloating}"/>
						<MenuItem Header="Dock Left" Command="{Binding SetDockStateCommand}" CommandParameter="Left" IsVisible="{Binding IsFloating}"/>
						<MenuItem Header="Dock Center" Command="{Binding SetDockStateCommand}" CommandParameter="Center" IsVisible="{Binding IsFloating}"/>
						<MenuItem Header="Dock Right" Command="{Binding SetDockStateCommand}" CommandParameter="Right" IsVisible="{Binding IsFloating}"/>
						<Separator/>
						<MenuItem Header="Close" Command="{Binding ClosePanelCommand}"/>
					</ContextMenu>
				</Border.ContextMenu>
				<Grid ColumnDefinitions="*, Auto, Auto, Auto, Auto, Auto">
					<!-- Panel Name -->
					<StackPanel Orientation="Horizontal" Grid.Column="0" Spacing="8" VerticalAlignment="Center">
						<TextBlock Text="Sprite Archive Viewer" FontWeight="SemiBold" Foreground="#E0E0E0" FontSize="13"/>
						<TextBlock Text="{Binding FileName, Mode=OneWay}" ToolTip.Tip="{Binding FilePath, Mode=OneWay}" FontSize="11" Foreground="#888888" VerticalAlignment="Center" TextTrimming="CharacterEllipsis"/>
					</StackPanel>
					
					<!-- Page Size Dropdown -->
					<StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center" Margin="0,0,8,0" Spacing="4" IsVisible="{Binding IsArchiveLoaded}">
						<TextBlock Text="Page size:" FontSize="10" Foreground="#888888" VerticalAlignment="Center"/>
						<ComboBox ItemsSource="{Binding AvailablePageSizes}" SelectedItem="{Binding PageSize}" FontSize="10" Height="22" Padding="6,2" BorderThickness="0" Background="#1E1E1E" CornerRadius="4"/>
					</StackPanel>

					<!-- Options Dropdown Button -->
					<Button Grid.Column="2" Width="28" Height="24" Background="Transparent" BorderThickness="0" CornerRadius="4" Margin="0,0,4,0" IsVisible="{Binding IsArchiveLoaded}">
						<Path Data="M2 12C2 13.1 2.9 14 4 14S6 13.1 6 12s-.9-2-2-2-2 .9-2 2zm10-2c-1.1 0-2 .9-2 2s.9 2 2 2 2-.9 2-2-.9-2-2-2zm6 0c-1.1 0-2 .9-2 2s.9 2 2 2 2-.9 2-2-.9-2-2-2z" Fill="#E0E0E0" Width="12" Height="12" Stretch="Uniform" HorizontalAlignment="Center" VerticalAlignment="Center"/>
						<Button.Flyout>
							<MenuFlyout Placement="BottomEdgeAlignedRight">
								<MenuItem Header="Save spr/assets" Command="{Binding RequestSaveConfirmationCommand}"/>
								<MenuItem Header="Save As..." Command="{Binding SaveAsCommand}"/>
							</MenuFlyout>
						</Button.Flyout>
					</Button>
					
					<!-- List/Grid Switcher Button -->
					<Button Grid.Column="3" Command="{Binding ToggleViewModeCommand}" Width="28" Height="24" Background="Transparent" BorderThickness="0" CornerRadius="4" Margin="0,0,4,0" IsVisible="{Binding IsArchiveLoaded}" ToolTip.Tip="Toggle List/Grid View">
						<Panel>
							<!-- List Icon (Visible when GridView is active, because clicking toggles to List) -->
							<Path Data="M2,4 L14,4 M2,8 L14,8 M2,12 L14,12" Stroke="#E0E0E0" StrokeThickness="1.5" Width="14" Height="14" Stretch="Uniform" HorizontalAlignment="Center" VerticalAlignment="Center" IsVisible="{Binding IsGridView}"/>
							<!-- Grid Icon (Visible when ListView is active, because clicking toggles to Grid) -->
							<Path Data="M1,1 H6 V6 H1 Z M9,1 H14 V6 H9 Z M1,9 H6 V14 H1 Z M9,9 H14 V14 H9 Z" Fill="#E0E0E0" Width="14" Height="14" Stretch="Uniform" HorizontalAlignment="Center" VerticalAlignment="Center" IsVisible="{Binding IsListView}"/>
						</Panel>
					</Button>
					
					<!-- Minimize Button -->
					<Button Grid.Column="4" Command="{Binding ToggleMinimizeCommand}" Width="28" Height="24" Background="Transparent" BorderThickness="0" CornerRadius="4" Margin="0,0,4,0">
						<Path Data="M 0,0 L 8,0" Stroke="#E0E0E0" StrokeThickness="1.5" HorizontalAlignment="Center" VerticalAlignment="Center"/>
					</Button>
					
					<!-- Close Button -->
					<Button Grid.Column="5" Command="{Binding ClosePanelCommand}" Width="28" Height="24" Background="Transparent" BorderThickness="0" CornerRadius="4">
						<Path Data="M 0,0 L 8,8 M 8,0 L 0,8" Stroke="#E0E0E0" StrokeThickness="1.5" HorizontalAlignment="Center" VerticalAlignment="Center"/>
					</Button>
				</Grid>
			</Border>

			<!-- Content Area (Scrollable Sprite Grid/List) -->
			<Grid Grid.Row="1" IsVisible="{Binding !IsMinimized}" Background="#1E1E1E" Height="{Binding DisplayHeight}">
				<!-- Grid View Mode -->
				<ListBox ItemsSource="{Binding PagedSprites, Mode=OneWay}" IsVisible="{Binding IsGridView, Mode=OneWay}" Background="Transparent" BorderThickness="0" ScrollViewer.HorizontalScrollBarVisibility="Disabled" Padding="8">
					<ListBox.ItemsPanel>
						<ItemsPanelTemplate>
							<WrapPanel Orientation="Horizontal" HorizontalAlignment="Center"/>
						</ItemsPanelTemplate>
					</ListBox.ItemsPanel>
					<ListBox.ItemTemplate>
						<DataTemplate x:DataType="sprites:SpriteViewModel">
							<Border Classes="sprite-tile" Classes.selected="{Binding IsSelected, Mode=OneWay}" Background="#2A2A2A" CornerRadius="6" Padding="8" Margin="4" Width="72" Height="76"
									PointerPressed="OnSpritePointerPressed">
								<Border.ContextMenu>
									<ContextMenu>
										<MenuItem Header="Copy" Command="{Binding CopyCommand}" InputGesture="Ctrl+C"/>
										<MenuItem Header="Paste" Command="{Binding PasteCommand}" InputGesture="Ctrl+V"/>
										<Separator/>
										<MenuItem Header="Import..." Command="{Binding ReplaceCommand}"/>
										<MenuItem Header="Export">
											<MenuItem Header="PNG" Command="{Binding ExportPngCommand}"/>
											<MenuItem Header="JPEG" Command="{Binding ExportJpegCommand}"/>
											<MenuItem Header="BMP" Command="{Binding ExportBmpCommand}"/>
										</MenuItem>
										<Separator/>
										<MenuItem Header="Remove" Command="{Binding RemoveCommand}"/>
									</ContextMenu>
								</Border.ContextMenu>
								<StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
									<Image Source="{Binding Preview, Mode=OneWay}" Width="32" Height="32" RenderOptions.BitmapInterpolationMode="None" HorizontalAlignment="Center" VerticalAlignment="Center"/>
									<TextBlock Text="{Binding Id, Mode=OneWay}" FontSize="10" Foreground="#888888" HorizontalAlignment="Center" Margin="0,6,0,0"/>
								</StackPanel>
							</Border>
						</DataTemplate>
					</ListBox.ItemTemplate>
				</ListBox>

				<!-- List View Mode -->
				<ListBox ItemsSource="{Binding PagedSprites, Mode=OneWay}" IsVisible="{Binding IsListView, Mode=OneWay}" Background="Transparent" BorderThickness="0" Padding="0">
					<ListBox.ItemsPanel>
						<ItemsPanelTemplate>
							<VirtualizingStackPanel/>
						</ItemsPanelTemplate>
					</ListBox.ItemsPanel>
					<ListBox.Styles>
						<Style Selector="ListBoxItem">
							<Setter Property="Padding" Value="0"/>
							<Setter Property="MinHeight" Value="42"/>
							<Setter Property="Background" Value="Transparent"/>
						</Style>
					</ListBox.Styles>
					<ListBox.ItemTemplate>
						<DataTemplate x:DataType="sprites:SpriteViewModel">
							<Border Classes="sprite-list-row" Classes.selected="{Binding IsSelected, Mode=OneWay}" BorderBrush="#2D2D2D" BorderThickness="0,0,0,1" Padding="8,3" PointerPressed="OnSpritePointerPressed">
								<Border.ContextMenu>
									<ContextMenu>
										<MenuItem Header="Copy" Command="{Binding CopyCommand}" InputGesture="Ctrl+C"/>
										<MenuItem Header="Paste" Command="{Binding PasteCommand}" InputGesture="Ctrl+V"/>
										<Separator/>
										<MenuItem Header="Import..." Command="{Binding ReplaceCommand}"/>
										<MenuItem Header="Export">
											<MenuItem Header="PNG" Command="{Binding ExportPngCommand}"/>
											<MenuItem Header="JPEG" Command="{Binding ExportJpegCommand}"/>
											<MenuItem Header="BMP" Command="{Binding ExportBmpCommand}"/>
										</MenuItem>
										<Separator/>
										<MenuItem Header="Remove" Command="{Binding RemoveCommand}"/>
									</ContextMenu>
								</Border.ContextMenu>
								<Grid ColumnDefinitions="Auto, *">
									<!-- Square Image Container -->
									<Border Grid.Column="0" Width="36" Height="36" Background="#1D1D1D" BorderBrush="#4A4A4A" BorderThickness="1" CornerRadius="4">
										<Image Source="{Binding Preview, Mode=OneWay}" Width="32" Height="32" Stretch="Uniform" RenderOptions.BitmapInterpolationMode="None"/>
									</Border>
									
									<!-- ID Text -->
									<TextBlock Grid.Column="1" Text="{Binding Id, Mode=OneWay}" VerticalAlignment="Center" Margin="12,0,0,0" Foreground="#E0E0E0" FontSize="13" FontWeight="SemiBold"/>
								</Grid>
							</Border>
						</DataTemplate>
					</ListBox.ItemTemplate>
				</ListBox>
				
				<StackPanel IsVisible="{Binding !TotalSprites}" VerticalAlignment="Center" HorizontalAlignment="Center" Spacing="12">
					<Border Name="EmptyStateDropzone"
							Background="#22000000"
							BorderBrush="#3A7BD5"
							BorderThickness="1.5"
							CornerRadius="8"
							Padding="18"
							Width="340"
							Cursor="Hand"
							PointerPressed="OnEmptyStateClick">
						<StackPanel Spacing="10" HorizontalAlignment="Center" VerticalAlignment="Center">
							<Path Data="M2 17L12 22L22 17M2 12L12 17L22 12M12 2L2 7L12 12L22 7L12 2Z" Fill="Transparent" Stroke="#3A7BD5" StrokeThickness="1.5" Width="24" Height="24" HorizontalAlignment="Center"/>
							<TextBlock Text="Click to Load Assets" FontWeight="SemiBold" Foreground="#3A7BD5" FontSize="13" HorizontalAlignment="Center"/>
							<TextBlock Text="Supports .spr and .assets archives" Foreground="#666666" FontSize="10" TextWrapping="Wrap" TextAlignment="Center" HorizontalAlignment="Center"/>
						</StackPanel>
					</Border>
					
					<!-- Loading Settings Container -->
					<Border Background="#252525" BorderBrush="#353535" BorderThickness="1" CornerRadius="6" Padding="12" Width="340">
						<StackPanel Spacing="8">
							<TextBlock Text="Loading Settings" FontSize="11" FontWeight="SemiBold" Foreground="#888888" Margin="0,0,0,4"/>
							<CheckBox Content="Transparent Pixels" IsChecked="{Binding UseTransparentPixels}" FontSize="11" Height="20"/>
							<CheckBox Content="Extended Sprite IDs" IsChecked="{Binding UseExtendedSpriteIds}" FontSize="11" Height="20"/>
						</StackPanel>
					</Border>
				</StackPanel>
			</Grid>

			<!-- Footer: sprite actions + pagination -->
			<Border Grid.Row="2" Name="BottomBar" IsVisible="{Binding !IsMinimized}" Background="#2D2D2D" BorderBrush="#3C3C3C" BorderThickness="0,1,0,0" Padding="8,6">
				<StackPanel Spacing="6">
					<StackPanel Orientation="Horizontal" Spacing="6" IsVisible="{Binding IsArchiveLoaded}">
						<Button Content="New Sprite" Command="{Binding NewSpriteCommand}" Padding="10,4" FontSize="11"/>
						<Border Width="1" Height="20" Background="#444444" Margin="2,0"/>
						<Button Content="Copy" Command="{Binding CopySelectedSpriteCommand}" Padding="10,4" FontSize="11"/>
						<Button Content="Paste" Command="{Binding PasteSelectedSpriteCommand}" Padding="10,4" FontSize="11"/>
						<Button Content="Import" Command="{Binding ImportSelectedSpritesCommand}" Padding="10,4" FontSize="11"/>
						<Button Content="Export" Padding="10,4" FontSize="11">
							<Button.Flyout>
								<MenuFlyout Placement="Top">
									<MenuItem Header="PNG" Command="{Binding ExportSelectedPngCommand}"/>
									<MenuItem Header="JPEG" Command="{Binding ExportSelectedJpegCommand}"/>
									<MenuItem Header="BMP" Command="{Binding ExportSelectedBmpCommand}"/>
								</MenuFlyout>
							</Button.Flyout>
						</Button>
						<Button Content="Remove" Command="{Binding RemoveSelectedSpritesCommand}" Padding="10,4" FontSize="11"/>
						<TextBlock Text="{Binding SelectedSpriteCount, StringFormat='{}{0} selected'}" Foreground="#888888" FontSize="10" VerticalAlignment="Center" Margin="8,0,0,0" IsVisible="{Binding HasSpriteSelection}"/>
					</StackPanel>

					<Grid ColumnDefinitions="Auto, Auto, *, Auto, Auto">
					<Button Grid.Column="0" Command="{Binding FirstPageCommand}" IsEnabled="{Binding HasPreviousPage}" Content="&lt;&lt;" Padding="8,4" FontSize="11" Margin="0,0,4,0"/>
					<Button Grid.Column="1" Command="{Binding PreviousPageCommand}" IsEnabled="{Binding HasPreviousPage}" Content="&lt;" Padding="8,4" FontSize="11"/>
					
					<StackPanel Grid.Column="2" Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Center" Spacing="6">
						<TextBlock Text="Page" Foreground="#888888" FontSize="12" VerticalAlignment="Center"/>
						<TextBox Text="{Binding CurrentPage, Mode=TwoWay}" Width="38" Height="22" Padding="2,1" FontSize="11" HorizontalContentAlignment="Center" VerticalContentAlignment="Center" Background="#1E1E1E" BorderThickness="0" CornerRadius="4" Foreground="#E0E0E0"/>
						<TextBlock Text="of" Foreground="#888888" FontSize="12" VerticalAlignment="Center"/>
						<TextBlock Text="{Binding TotalPages}" FontWeight="Bold" Foreground="#E0E0E0" FontSize="12" VerticalAlignment="Center"/>
						<TextBlock Text="(" Foreground="#666666" FontSize="10" VerticalAlignment="Center" Margin="4,0,0,0"/>
						<TextBlock Text="{Binding TotalSprites}" Foreground="#666666" FontSize="10" VerticalAlignment="Center"/>
						<TextBlock Text="sprites)" Foreground="#666666" FontSize="10" VerticalAlignment="Center"/>
					</StackPanel>
					
					<Button Grid.Column="3" Command="{Binding NextPageCommand}" IsEnabled="{Binding HasNextPage}" Content="&gt;" Padding="8,4" FontSize="11" Margin="0,0,4,0"/>
					<Button Grid.Column="4" Command="{Binding LastPageCommand}" IsEnabled="{Binding HasNextPage}" Content="&gt;&gt;" Padding="8,4" FontSize="11"/>
					</Grid>
				</StackPanel>
			</Border>

			<!-- Resize Handles (Overlay) -->
			<!-- Left edge resize handle -->
			<Border Grid.RowSpan="3" Width="5" HorizontalAlignment="Left" Background="Transparent" Cursor="SizeWestEast" 
			        IsVisible="{Binding ShowResizeHandles}"
			        PointerPressed="OnResizeLeftPressed" 
			        PointerMoved="OnResizeLeftMoved" 
			        PointerReleased="OnResizeReleased"/>

			<!-- Right edge resize handle -->
			<Border Grid.RowSpan="3" Width="5" HorizontalAlignment="Right" Background="Transparent" Cursor="SizeWestEast" 
					IsVisible="{Binding ShowResizeHandles}"
					PointerPressed="OnResizeRightPressed" 
					PointerMoved="OnResizeRightMoved" 
					PointerReleased="OnResizeReleased"/>
			
			<!-- Bottom edge resize handle -->
			<Border Grid.Row="2" Height="5" VerticalAlignment="Bottom" Background="Transparent" Cursor="SizeNorthSouth" 
					IsVisible="{Binding ShowResizeHandles}"
					PointerPressed="OnResizeBottomPressed" 
					PointerMoved="OnResizeBottomMoved" 
					PointerReleased="OnResizeReleased"/>
			
			<!-- Bottom-right corner resize handle -->
			<Border Grid.Row="2" Width="10" Height="10" HorizontalAlignment="Right" VerticalAlignment="Bottom" Background="Transparent" Cursor="BottomRightCorner" 
					IsVisible="{Binding ShowResizeHandles}"
					PointerPressed="OnResizeCornerPressed" 
					PointerMoved="OnResizeCornerMoved" 
					PointerReleased="OnResizeReleased"/>
			
			<!-- Bottom-left corner resize handle -->
			<Border Grid.Row="2" Width="10" Height="10" HorizontalAlignment="Left" VerticalAlignment="Bottom" Background="Transparent" Cursor="BottomLeftCorner" 
					IsVisible="{Binding ShowResizeHandles}"
					PointerPressed="OnResizeBottomLeftPressed" 
					PointerMoved="OnResizeBottomLeftMoved" 
					PointerReleased="OnResizeReleased"/>
			<!-- Save Confirmation Overlay -->
			<Border Grid.Row="0" Grid.RowSpan="3" Background="#B0000000" IsVisible="{Binding ShowSaveConfirmation}" CornerRadius="8">
				<Border Background="#2A2A2A" BorderBrush="#444444" BorderThickness="1" CornerRadius="8" Padding="16" Width="340" HorizontalAlignment="Center" VerticalAlignment="Center" BoxShadow="0 4 12 0 #7F000000">
					<StackPanel Spacing="12">
						<TextBlock Text="Save Changes?" FontWeight="Bold" Foreground="#FFFFFF" HorizontalAlignment="Center" FontSize="13"/>
						<TextBlock Text="Are you sure you want to save a backup (.bak) of this archive?" FontSize="11" Foreground="#CCCCCC" TextWrapping="Wrap" TextAlignment="Center"/>
						<Grid ColumnDefinitions="*, *" Margin="0,8,0,0">
							<Button Grid.Column="0" Content="Cancel" Command="{Binding CancelSaveCommand}" Margin="0,0,4,0" HorizontalAlignment="Stretch" HorizontalContentAlignment="Center" FontSize="11" Padding="0,6"/>
							<Button Grid.Column="1" Content="Confirm" Command="{Binding ConfirmSaveCommand}" Background="#3A7BD5" Foreground="White" Margin="4,0,0,0" HorizontalAlignment="Stretch" HorizontalContentAlignment="Center" FontSize="11" Padding="0,6"/>
						</Grid>
					</StackPanel>
				</Border>
			</Border>
		</Grid>
	</Border>
</UserControl>
