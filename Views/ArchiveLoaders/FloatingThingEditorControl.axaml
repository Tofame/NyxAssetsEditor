<UserControl xmlns="https://github.com/avaloniaui"
			 xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
			 xmlns:vm="using:NyxAssetsEditor.ViewModels.ArchiveLoaders"
			 x:Class="NyxAssetsEditor.Views.ArchiveLoaders.FloatingThingEditorControl"
			 x:DataType="vm:FloatingThingEditorViewModel"
			 Width="{Binding DisplayWidth}">

	<UserControl.Styles>
		<Style Selector="Button.selected">
			<Setter Property="Background" Value="#335E94FF"/>
			<Setter Property="BorderBrush" Value="#5E94FF"/>
		</Style>
	</UserControl.Styles>

	<Border Background="#252525" BorderBrush="#3C3C3C" BorderThickness="1" CornerRadius="8" BoxShadow="0 4 12 0 #7F000000">
		<Grid RowDefinitions="Auto, *">
			<Border Grid.Row="0" Name="TitleBar" Background="#2D2D2D" Height="36" Padding="12,0,6,0">
				<Border.ContextMenu>
					<ContextMenu>
						<MenuItem Header="Undock" Command="{Binding UndockCommand}" IsVisible="{Binding !IsFloating}"/>
						<MenuItem Header="Dock Left" Command="{Binding SetDockStateCommand}" CommandParameter="Left" IsVisible="{Binding IsFloating}"/>
						<MenuItem Header="Dock Center" Command="{Binding SetDockStateCommand}" CommandParameter="Center" IsVisible="{Binding IsFloating}"/>
						<MenuItem Header="Dock Right" Command="{Binding SetDockStateCommand}" CommandParameter="Right" IsVisible="{Binding IsFloating}"/>
						<Separator/>
						<MenuItem Header="Close" Command="{Binding ClosePanelCommand}"/>
					</ContextMenu>
				</Border.ContextMenu>
				<Grid ColumnDefinitions="*, Auto, Auto">
					<TextBlock Text="{Binding Title, Mode=OneWay}" FontWeight="SemiBold" Foreground="#E0E0E0" FontSize="13" VerticalAlignment="Center"/>
					<Button Grid.Column="1" Command="{Binding ToggleMinimizeCommand}" Width="28" Height="24" Background="Transparent" BorderThickness="0" Margin="0,0,4,0">
						<Path Data="M 0,0 L 8,0" Stroke="#E0E0E0" StrokeThickness="1.5" HorizontalAlignment="Center" VerticalAlignment="Center"/>
					</Button>
					<Button Grid.Column="2" Command="{Binding ClosePanelCommand}" Width="28" Height="24" Background="Transparent" BorderThickness="0">
						<Path Data="M 0,0 L 8,8 M 8,0 L 0,8" Stroke="#E0E0E0" StrokeThickness="1.5" HorizontalAlignment="Center" VerticalAlignment="Center"/>
					</Button>
				</Grid>
			</Border>

			<TabControl Grid.Row="1" IsVisible="{Binding !IsMinimized}" Background="#222222" Height="{Binding DisplayHeight}" Padding="8">
				<TabItem Header="Texture">
					<ScrollViewer HorizontalScrollBarVisibility="Disabled">
						<StackPanel Spacing="12" Margin="0,8,0,16">

							<!-- Appearance -->
							<Border Background="#1E1E1E" CornerRadius="6" Padding="12" BorderBrush="#353535" BorderThickness="1">
								<StackPanel Spacing="10">
									<TextBlock Text="Appearance" FontWeight="SemiBold" Foreground="#CCCCCC" FontSize="12"/>

									<!-- Outfit directions -->
									<Grid IsVisible="{Binding ShowOutfitDirections}" ColumnDefinitions="*,Auto,*" RowDefinitions="Auto,Auto,Auto" HorizontalAlignment="Center" Width="120">
										<Button Grid.Row="0" Grid.Column="1" Classes.selected="{Binding IsDirectionNorth}" Command="{Binding SetDirectionNorthCommand}" Content="^" Width="32" Height="28" Margin="2"/>
										<Button Grid.Row="1" Grid.Column="0" Classes.selected="{Binding IsDirectionWest}" Command="{Binding SetDirectionWestCommand}" Content="&lt;" Width="32" Height="28" Margin="2"/>
										<Button Grid.Row="1" Grid.Column="1" Classes.selected="{Binding IsDirectionSouth}" Command="{Binding SetDirectionSouthCommand}" Content="v" Width="32" Height="28" Margin="2"/>
										<Button Grid.Row="1" Grid.Column="2" Classes.selected="{Binding IsDirectionEast}" Command="{Binding SetDirectionEastCommand}" Content="&gt;" Width="32" Height="28" Margin="2"/>
									</Grid>

									<!-- Missile directions -->
									<WrapPanel IsVisible="{Binding ShowMissileDirections}" HorizontalAlignment="Center" MaxWidth="280">
										<Button Command="{Binding SetMissileDirectionCommand}" CommandParameter="NorthWest" Content="NW" Margin="2" Padding="6,4" FontSize="10"/>
										<Button Command="{Binding SetMissileDirectionCommand}" CommandParameter="North" Content="N" Margin="2" Padding="6,4" FontSize="10"/>
										<Button Command="{Binding SetMissileDirectionCommand}" CommandParameter="NorthEast" Content="NE" Margin="2" Padding="6,4" FontSize="10"/>
										<Button Command="{Binding SetMissileDirectionCommand}" CommandParameter="West" Content="W" Margin="2" Padding="6,4" FontSize="10"/>
										<Button Command="{Binding SetMissileDirectionCommand}" CommandParameter="East" Content="E" Margin="2" Padding="6,4" FontSize="10"/>
										<Button Command="{Binding SetMissileDirectionCommand}" CommandParameter="SouthWest" Content="SW" Margin="2" Padding="6,4" FontSize="10"/>
										<Button Command="{Binding SetMissileDirectionCommand}" CommandParameter="South" Content="S" Margin="2" Padding="6,4" FontSize="10"/>
										<Button Command="{Binding SetMissileDirectionCommand}" CommandParameter="SouthEast" Content="SE" Margin="2" Padding="6,4" FontSize="10"/>
									</WrapPanel>

									<Grid ColumnDefinitions="*,Auto" RowDefinitions="Auto,Auto">
										<!-- Preview: full pattern grid for items/effects (OB updateView) -->
										<ScrollViewer Grid.Row="0" Grid.Column="0" Grid.RowSpan="2"
													  HorizontalScrollBarVisibility="Auto"
													  VerticalScrollBarVisibility="Auto"
													  MaxHeight="360"
													  Margin="0,0,12,0">
											<Border Background="#141414" BorderBrush="#444444" BorderThickness="1" CornerRadius="4" Padding="8"
													HorizontalAlignment="Left" VerticalAlignment="Top" MinWidth="80" MinHeight="80">
												<Image Source="{Binding AppearanceImage, Mode=OneWay}" Stretch="None" RenderOptions.BitmapInterpolationMode="None"
													   HorizontalAlignment="Left" VerticalAlignment="Top"/>
											</Border>
										</ScrollViewer>

										<!-- Layer slider (Object Builder: right of preview) -->
										<StackPanel Grid.Row="0" Grid.Column="1" Spacing="4" VerticalAlignment="Top" MinWidth="140"
													IsVisible="{Binding ShowLayerSlider}">
											<TextBlock Text="Layer:" Foreground="#888" FontSize="11"/>
											<Grid ColumnDefinitions="*,Auto">
												<Slider Grid.Column="0" Minimum="0" Maximum="{Binding LayerMaximum}" Value="{Binding SelectedLayer}" VerticalAlignment="Center"/>
												<TextBlock Grid.Column="1" Text="{Binding LayerDisplay, Mode=OneWay}" Foreground="#AAA" FontSize="11" VerticalAlignment="Center" Margin="8,0,0,0" MinWidth="28"/>
											</Grid>
										</StackPanel>

										<!-- Other appearance sliders -->
										<StackPanel Grid.Row="1" Grid.Column="0" Grid.ColumnSpan="2" Spacing="6" Margin="0,10,0,0">
											<StackPanel Orientation="Horizontal" Spacing="8" IsVisible="{Binding ShowFrameGroupSlider}">
												<TextBlock Text="Frame group" Width="90" Foreground="#888" FontSize="11" VerticalAlignment="Center"/>
												<Slider Minimum="0" Maximum="{Binding FrameGroupMaximum}" Value="{Binding SelectedFrameGroupIndex}" Width="180"/>
											</StackPanel>
											<StackPanel Orientation="Horizontal" Spacing="8" IsVisible="{Binding ShowFrameSlider}">
												<TextBlock Text="Animation" Width="90" Foreground="#888" FontSize="11" VerticalAlignment="Center"/>
												<Slider Minimum="0" Maximum="{Binding FrameMaximum}" Value="{Binding SelectedFrame}" Width="140"/>
												<TextBlock Text="{Binding FrameDisplay, Mode=OneWay}" Foreground="#AAA" FontSize="11" VerticalAlignment="Center" MinWidth="28"/>
											</StackPanel>
											<StackPanel Orientation="Horizontal" Spacing="8" IsVisible="{Binding ShowPatternXSlider}">
												<TextBlock Text="Pattern X" Width="90" Foreground="#888" FontSize="11" VerticalAlignment="Center"/>
												<Slider Minimum="0" Maximum="{Binding PatternXMaximum}" Value="{Binding ViewPatternXIndex}" Width="140"/>
												<TextBlock Text="{Binding PatternXDisplay, Mode=OneWay}" Foreground="#AAA" FontSize="11" VerticalAlignment="Center" MinWidth="28"/>
											</StackPanel>
											<StackPanel Orientation="Horizontal" Spacing="8" IsVisible="{Binding ShowPatternYSlider}">
												<TextBlock Text="Pattern Y" Width="90" Foreground="#888" FontSize="11" VerticalAlignment="Center"/>
												<Slider Minimum="0" Maximum="{Binding PatternYMaximum}" Value="{Binding ViewPatternYIndex}" Width="140"/>
												<TextBlock Text="{Binding PatternYDisplay, Mode=OneWay}" Foreground="#AAA" FontSize="11" VerticalAlignment="Center" MinWidth="28"/>
											</StackPanel>
											<StackPanel Orientation="Horizontal" Spacing="8" IsVisible="{Binding ShowAddonSlider}">
												<TextBlock Text="Addon" Width="90" Foreground="#888" FontSize="11" VerticalAlignment="Center"/>
												<Slider Minimum="0" Maximum="{Binding AddonMaximum}" Value="{Binding ViewPatternYIndex}" Width="140"/>
												<TextBlock Text="{Binding PatternYDisplay, Mode=OneWay}" Foreground="#AAA" FontSize="11" VerticalAlignment="Center" MinWidth="28"/>
											</StackPanel>
											<StackPanel Orientation="Horizontal" Spacing="8" IsVisible="{Binding ShowPatternZSlider}">
												<TextBlock Text="Mount" Width="90" Foreground="#888" FontSize="11" VerticalAlignment="Center"/>
												<Slider Minimum="0" Maximum="{Binding PatternZMaximum}" Value="{Binding ViewPatternZIndex}" Width="140"/>
											</StackPanel>
										</StackPanel>
									</Grid>

									<StackPanel Orientation="Horizontal" Spacing="16" Margin="0,8,0,0">
										<ToggleSwitch Content="Show Crop Size" IsChecked="{Binding ShowCropSize}" OnContent="" OffContent="" FontSize="11"/>
										<ToggleSwitch Content="Show Grid" IsChecked="{Binding ShowGrid}" OnContent="" OffContent="" FontSize="11"/>
									</StackPanel>

									<StackPanel IsVisible="{Binding ShowDurationEditors}" Spacing="8">
										<TextBlock Text="Frame duration (ms)" FontSize="11" Foreground="#888"/>
										<Grid ColumnDefinitions="Auto,*,Auto,*" RowDefinitions="Auto,Auto">
											<TextBlock Grid.Row="0" Grid.Column="0" Text="Min" Foreground="#888" FontSize="11" VerticalAlignment="Center" Margin="0,0,8,0"/>
											<NumericUpDown Grid.Row="0" Grid.Column="1" Value="{Binding MinimumDuration}" Minimum="0" Maximum="60000" Width="100" FontSize="11"/>
											<TextBlock Grid.Row="0" Grid.Column="2" Text="Max" Foreground="#888" FontSize="11" VerticalAlignment="Center" Margin="12,0,8,0"/>
											<NumericUpDown Grid.Row="0" Grid.Column="3" Value="{Binding MaximumDuration}" Minimum="0" Maximum="60000" Width="100" FontSize="11"/>
											<Button Grid.Row="1" Grid.Column="0" Grid.ColumnSpan="2" Content="Default durations" Command="{Binding ApplyDefaultDurationsCommand}" Margin="0,8,4,0" FontSize="11" HorizontalAlignment="Stretch"/>
											<Button Grid.Row="1" Grid.Column="2" Grid.ColumnSpan="2" Content="Set for all frames" Command="{Binding ApplyDurationForAllFramesCommand}" Margin="4,8,0,0" FontSize="11" HorizontalAlignment="Stretch"/>
										</Grid>
									</StackPanel>
								</StackPanel>
							</Border>

							<!-- Patterns -->
							<Border Background="#1E1E1E" CornerRadius="6" Padding="12" BorderBrush="#353535" BorderThickness="1" IsVisible="{Binding HasPatterns}">
								<StackPanel Spacing="8" x:CompileBindings="False">
									<TextBlock Text="Patterns" FontWeight="SemiBold" Foreground="#CCCCCC" FontSize="12"/>
									<Grid ColumnDefinitions="90,Auto" RowDefinitions="Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto" HorizontalAlignment="Left">
										<TextBlock Grid.Row="0" Grid.Column="0" Text="Width:" Foreground="#888" FontSize="11" VerticalAlignment="Center" Margin="0,0,8,4"/>
										<NumericUpDown x:Name="PatternTileWidthNud" Grid.Row="0" Grid.Column="1" Minimum="1" Maximum="32" Increment="1" Width="100" FontSize="11" Margin="0,0,0,4"/>
										<TextBlock Grid.Row="1" Grid.Column="0" Text="Height:" Foreground="#888" FontSize="11" VerticalAlignment="Center" Margin="0,0,8,4"/>
										<NumericUpDown x:Name="PatternTileHeightNud" Grid.Row="1" Grid.Column="1" Minimum="1" Maximum="32" Increment="1" Width="100" FontSize="11" Margin="0,0,0,4"/>
										<TextBlock Grid.Row="2" Grid.Column="0" Text="Crop Size:" Foreground="#888" FontSize="11" VerticalAlignment="Center" Margin="0,0,8,4"/>
										<NumericUpDown x:Name="PatternCropSizeNud" Grid.Row="2" Grid.Column="1" Minimum="1" Maximum="64" Increment="1" Width="100" FontSize="11" Margin="0,0,0,4"/>
										<TextBlock Grid.Row="3" Grid.Column="0" Text="Layers:" Foreground="#888" FontSize="11" VerticalAlignment="Center" Margin="0,0,8,4"/>
										<NumericUpDown x:Name="PatternLayerCountNud" Grid.Row="3" Grid.Column="1" Minimum="1" Maximum="16" Increment="1" Width="100" FontSize="11" Margin="0,0,0,4"/>
										<TextBlock Grid.Row="4" Grid.Column="0" Text="Pattern X:" Foreground="#888" FontSize="11" VerticalAlignment="Center" Margin="0,0,8,4"/>
										<NumericUpDown x:Name="PatternXCountNud" Grid.Row="4" Grid.Column="1" Minimum="1" Maximum="32" Increment="1" Width="100" FontSize="11" Margin="0,0,0,4"/>
										<TextBlock Grid.Row="5" Grid.Column="0" Text="Pattern Y:" Foreground="#888" FontSize="11" VerticalAlignment="Center" Margin="0,0,8,4"/>
										<NumericUpDown x:Name="PatternYCountNud" Grid.Row="5" Grid.Column="1" Minimum="1" Maximum="32" Increment="1" Width="100" FontSize="11" Margin="0,0,0,4"/>
										<TextBlock Grid.Row="6" Grid.Column="0" Text="Pattern Z:" Foreground="#888" FontSize="11" VerticalAlignment="Center" Margin="0,0,8,4"/>
										<NumericUpDown x:Name="PatternZCountNud" Grid.Row="6" Grid.Column="1" Minimum="1" Maximum="16" Increment="1" Width="100" FontSize="11" Margin="0,0,0,4"/>
										<TextBlock Grid.Row="7" Grid.Column="0" Text="Animations:" Foreground="#888" FontSize="11" VerticalAlignment="Center" Margin="0,0,8,0"/>
										<NumericUpDown x:Name="PatternFrameCountNud" Grid.Row="7" Grid.Column="1" Minimum="1" Maximum="60" Increment="1" Width="100" FontSize="11"/>
									</Grid>
								</StackPanel>
							</Border>

							<!-- Animation -->
							<Border Background="#1E1E1E" CornerRadius="6" Padding="12" BorderBrush="#353535" BorderThickness="1" IsVisible="{Binding ShowAnimationSection}">
								<StackPanel Spacing="8">
									<TextBlock Text="Animation" FontWeight="SemiBold" Foreground="#CCCCCC" FontSize="12"/>
									<StackPanel Orientation="Horizontal" Spacing="8">
										<TextBlock Text="Mode" Width="90" Foreground="#888" FontSize="11" VerticalAlignment="Center"/>
										<ComboBox ItemsSource="{Binding AnimationModes, Mode=OneWay}" SelectedIndex="{Binding SelectedAnimationMode}" Width="160" FontSize="11"/>
									</StackPanel>
									<StackPanel Orientation="Horizontal" Spacing="8">
										<TextBlock Text="Frame strategy" Width="90" Foreground="#888" FontSize="11" VerticalAlignment="Center"/>
										<ComboBox ItemsSource="{Binding FrameStrategies, Mode=OneWay}" SelectedIndex="{Binding FrameStrategyIndex}" Width="160" FontSize="11"/>
									</StackPanel>
									<StackPanel Orientation="Horizontal" Spacing="8" IsVisible="{Binding ShowLoopCountEditor}">
										<TextBlock Text="Loop count" Width="90" Foreground="#888" FontSize="11" VerticalAlignment="Center"/>
										<NumericUpDown Value="{Binding AnimationLoopCount}" Minimum="0" Maximum="{Binding LoopCountMaximum}" Width="100" FontSize="11"/>
									</StackPanel>
									<StackPanel Orientation="Horizontal" Spacing="8">
										<TextBlock Text="Start frame" Width="90" Foreground="#888" FontSize="11" VerticalAlignment="Center"/>
										<NumericUpDown Value="{Binding AnimationStartFrame}" Minimum="-1" Maximum="{Binding StartFrameMaximum}" Width="100" FontSize="11"/>
									</StackPanel>
								</StackPanel>
							</Border>

						</StackPanel>
					</ScrollViewer>
				</TabItem>

				<TabItem Header="Properties">
					<ScrollViewer>
						<StackPanel Spacing="8" Margin="0,8,0,16">
							<CheckBox Content="Stackable" IsChecked="{Binding Stackable}" IsVisible="{Binding IsItem}" FontSize="11"/>
							<CheckBox Content="Rotatable" IsChecked="{Binding Rotatable}" IsVisible="{Binding IsItem}" FontSize="11"/>
							<CheckBox Content="Pickupable" IsChecked="{Binding Pickupable}" FontSize="11"/>
							<CheckBox Content="Block missile" IsChecked="{Binding BlockMissile}" IsVisible="{Binding !IsMissile}" FontSize="11"/>
							<CheckBox Content="Animate always" IsChecked="{Binding AnimateAlways}" IsVisible="{Binding IsOutfit}" FontSize="11"/>
							<CheckBox Content="Don't center outfit" IsChecked="{Binding DontCenterOutfit}" IsVisible="{Binding IsOutfit}" FontSize="11"/>
							<CheckBox Content="Bottom effect" IsChecked="{Binding BottomEffect}" IsVisible="{Binding IsEffect}" FontSize="11"/>
						</StackPanel>
					</ScrollViewer>
				</TabItem>
			</TabControl>

			<!-- Resize handles -->
			<Border Grid.RowSpan="2" Name="ResizeLeft" Width="5" HorizontalAlignment="Left" Background="Transparent" Cursor="SizeWestEast"
					IsVisible="{Binding ShowResizeHandles}"/>
			<Border Grid.RowSpan="2" Name="ResizeRight" Width="5" HorizontalAlignment="Right" Background="Transparent" Cursor="SizeWestEast"
					IsVisible="{Binding ShowResizeHandles}"/>
			<Border Grid.Row="1" Name="ResizeBottom" Height="5" VerticalAlignment="Bottom" Background="Transparent" Cursor="SizeNorthSouth"
					IsVisible="{Binding ShowResizeHandles}"/>
			<Border Grid.Row="1" Name="ResizeCorner" Width="10" Height="10" HorizontalAlignment="Right" VerticalAlignment="Bottom" Background="Transparent" Cursor="BottomRightCorner"
					IsVisible="{Binding ShowResizeHandles}"/>
			<Border Grid.Row="1" Name="ResizeBottomLeft" Width="10" Height="10" HorizontalAlignment="Left" VerticalAlignment="Bottom" Background="Transparent" Cursor="BottomLeftCorner"
					IsVisible="{Binding ShowResizeHandles}"/>
		</Grid>
	</Border>
</UserControl>
