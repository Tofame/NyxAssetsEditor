<UserControl xmlns="https://github.com/avaloniaui"
			 xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
			 xmlns:vm="using:NyxAssetsEditor.ViewModels.ArchiveLoaders"
			 x:Class="NyxAssetsEditor.Views.ArchiveLoaders.FloatingThingEditorControl"
			 x:DataType="vm:FloatingThingEditorViewModel"
			 Width="{Binding DisplayWidth}">

	<UserControl.Resources>
		<ControlTheme x:Key="FlatSliderTheme" TargetType="Slider">
			<Setter Property="Background" Value="#252525"/>
			<Setter Property="Foreground" Value="#707070"/>
			<Setter Property="Height" Value="14"/>
			<Setter Property="MinHeight" Value="14"/>
			<Setter Property="Margin" Value="0"/>
			<Setter Property="Padding" Value="0"/>
			<Setter Property="Template">
				<ControlTemplate>
					<Border Background="{TemplateBinding Background}"
							BorderBrush="#3D3D3D"
							BorderThickness="1"
							CornerRadius="1"
							Height="14"
							VerticalAlignment="Center">
						<Track Name="PART_Track"
							   Minimum="{TemplateBinding Minimum}"
							   Maximum="{TemplateBinding Maximum}"
							   Value="{TemplateBinding Value, Mode=TwoWay}"
							   Orientation="Horizontal">
							<Track.DecreaseButton>
								<RepeatButton Background="Transparent" BorderThickness="0" HorizontalAlignment="Stretch" VerticalAlignment="Stretch"/>
							</Track.DecreaseButton>
							<Track.IncreaseButton>
								<RepeatButton Background="Transparent" BorderThickness="0" HorizontalAlignment="Stretch" VerticalAlignment="Stretch"/>
							</Track.IncreaseButton>
							<Thumb Name="thumb" Width="10" Height="12" Margin="0" Padding="0">
								<Thumb.Template>
									<ControlTemplate>
										<Border Name="ThumbBorder"
												Background="{TemplateBinding Foreground}"
												BorderBrush="#555555"
												BorderThickness="1"
												CornerRadius="1"/>
									</ControlTemplate>
								</Thumb.Template>
								<Thumb.Styles>
									<Style Selector="Thumb:pointerover /template/ Border#ThumbBorder">
										<Setter Property="Background" Value="#8A8A8A"/>
										<Setter Property="BorderBrush" Value="#6A6A6A"/>
									</Style>
									<Style Selector="Thumb:pressed /template/ Border#ThumbBorder">
										<Setter Property="Background" Value="#A0A0A0"/>
										<Setter Property="BorderBrush" Value="#8A8A8A"/>
									</Style>
								</Thumb.Styles>
							</Thumb>
						</Track>
					</Border>
				</ControlTemplate>
			</Setter>
		</ControlTheme>
	</UserControl.Resources>

	<UserControl.Styles>
		<Style Selector="Button.selected">
			<Setter Property="Background" Value="#335E94FF"/>
			<Setter Property="BorderBrush" Value="#5E94FF"/>
		</Style>
		<Style Selector="Button.icon-btn">
			<Setter Property="Width" Value="22"/>
			<Setter Property="Height" Value="22"/>
			<Setter Property="Padding" Value="0"/>
			<Setter Property="Background" Value="#2A2A2A"/>
			<Setter Property="BorderBrush" Value="#444444"/>
			<Setter Property="BorderThickness" Value="1"/>
			<Setter Property="CornerRadius" Value="3"/>
		</Style>
	</UserControl.Styles>

	<Border Background="#252525" BorderBrush="#3C3C3C" BorderThickness="1" CornerRadius="8" BoxShadow="0 4 12 0 #7F000000">
		<Grid RowDefinitions="Auto, *, Auto">
			<Border Grid.Row="0" Name="TitleBar" Background="#2D2D2D" Height="36" Padding="12,0,6,0">
				<Border.ContextMenu>
					<ContextMenu>
						<MenuItem Header="Undock" Command="{Binding UndockCommand}" IsVisible="{Binding !IsFloating}"/>
						<MenuItem Header="Dock Left" Command="{Binding SetDockStateCommand}" CommandParameter="Left" IsVisible="{Binding IsFloating}"/>
						<MenuItem Header="Dock Center" Command="{Binding SetDockStateCommand}" CommandParameter="Center" IsVisible="{Binding IsFloating}"/>
						<MenuItem Header="Dock Right" Command="{Binding SetDockStateCommand}" CommandParameter="Right" IsVisible="{Binding IsFloating}"/>
						<Separator/>
						<MenuItem Header="Close" Command="{Binding ClosePanelCommand}"/>
					</ContextMenu>
				</Border.ContextMenu>
				<Grid ColumnDefinitions="*, Auto, Auto">
					<TextBlock Text="{Binding Title, Mode=OneWay}" FontWeight="SemiBold" Foreground="#E0E0E0" FontSize="13" VerticalAlignment="Center"/>
					<Button Grid.Column="1" Command="{Binding ToggleMinimizeCommand}" Width="28" Height="24" Background="Transparent" BorderThickness="0" Margin="0,0,4,0">
						<Path Data="M 0,0 L 8,0" Stroke="#E0E0E0" StrokeThickness="1.5" HorizontalAlignment="Center" VerticalAlignment="Center"/>
					</Button>
					<Button Grid.Column="2" Command="{Binding ClosePanelCommand}" Width="28" Height="24" Background="Transparent" BorderThickness="0">
						<Path Data="M 0,0 L 8,8 M 8,0 L 0,8" Stroke="#E0E0E0" StrokeThickness="1.5" HorizontalAlignment="Center" VerticalAlignment="Center"/>
					</Button>
				</Grid>
			</Border>

			<TabControl Grid.Row="1" IsVisible="{Binding !IsMinimized}" Background="#222222" Height="{Binding DisplayHeight}" Padding="8">
				<TabItem Header="Texture">
					<ScrollViewer HorizontalScrollBarVisibility="Disabled">
						<StackPanel Spacing="12" Margin="0,8,0,16">

							<!-- Appearance -->
							<Border Background="#1E1E1E" CornerRadius="6" Padding="12" BorderBrush="#353535" BorderThickness="1">
								<StackPanel Spacing="8">
									<TextBlock Text="Appearance" FontWeight="SemiBold" Foreground="#CCCCCC" FontSize="12"/>

									<!-- Outfit directions -->
									<Grid IsVisible="{Binding ShowOutfitDirections}" ColumnDefinitions="*,Auto,*" RowDefinitions="Auto,Auto,Auto" HorizontalAlignment="Center" Width="120">
										<Button Grid.Row="0" Grid.Column="1" Classes.selected="{Binding IsDirectionNorth}" Command="{Binding SetDirectionNorthCommand}" Content="^" Width="32" Height="28" Margin="2"/>
										<Button Grid.Row="1" Grid.Column="0" Classes.selected="{Binding IsDirectionWest}" Command="{Binding SetDirectionWestCommand}" Content="&lt;" Width="32" Height="28" Margin="2"/>
										<Button Grid.Row="1" Grid.Column="1" Classes.selected="{Binding IsDirectionSouth}" Command="{Binding SetDirectionSouthCommand}" Content="v" Width="32" Height="28" Margin="2"/>
										<Button Grid.Row="1" Grid.Column="2" Classes.selected="{Binding IsDirectionEast}" Command="{Binding SetDirectionEastCommand}" Content="&gt;" Width="32" Height="28" Margin="2"/>
									</Grid>

									<!-- Preview (centered) -->
									<ScrollViewer HorizontalAlignment="Center"
												  HorizontalScrollBarVisibility="Auto"
												  VerticalScrollBarVisibility="Auto"
												  MaxHeight="360"
												  MaxWidth="480">
										<Border x:Name="AppearanceDropTarget"
												DragDrop.AllowDrop="True"
												DragDrop.DragEnter="OnAppearanceDragEnter"
												DragDrop.DragLeave="OnAppearanceDragLeave"
												DragDrop.DragOver="OnAppearanceDragOver"
												DragDrop.Drop="OnAppearanceDrop"
												Background="#141414" BorderBrush="#444444" BorderThickness="1" CornerRadius="4" Padding="8"
												HorizontalAlignment="Center" VerticalAlignment="Top" MinWidth="80" MinHeight="80">
											<Image x:Name="AppearanceImageControl" Source="{Binding AppearanceImage, Mode=OneWay}" Stretch="None" RenderOptions.BitmapInterpolationMode="None"
												   HorizontalAlignment="Center" VerticalAlignment="Center"/>
										</Border>
									</ScrollViewer>

									<!-- Controls (right-aligned, OB-style) -->
									<StackPanel Spacing="6" HorizontalAlignment="Right" Margin="0,4,0,0">
										<Grid ColumnDefinitions="70,168,80" IsVisible="{Binding ShowFrameGroupSlider}">
											<TextBlock Grid.Column="0" Text="Group:" Foreground="#888" FontSize="11" VerticalAlignment="Center" HorizontalAlignment="Right" Margin="0,0,8,0"/>
											<Slider Grid.Column="1" Theme="{StaticResource FlatSliderTheme}" Minimum="0" Maximum="{Binding FrameGroupMaximum}" Value="{Binding SelectedFrameGroupIndex}" VerticalAlignment="Center" IsSnapToTickEnabled="True" TickFrequency="1" SmallChange="1" LargeChange="1"/>
											<TextBlock Grid.Column="2" Text="{Binding FrameGroupDisplay, Mode=OneWay}" Foreground="#AAA" FontSize="11" VerticalAlignment="Center" Margin="8,0,0,0"/>
										</Grid>

										<Grid ColumnDefinitions="70,168,80" IsVisible="{Binding ShowFrameSlider}">
											<TextBlock Grid.Column="0" Text="Animation:" Foreground="#888" FontSize="11" VerticalAlignment="Center" HorizontalAlignment="Right" Margin="0,0,8,0"/>
											<Slider Grid.Column="1" Theme="{StaticResource FlatSliderTheme}" Minimum="0" Maximum="{Binding FrameMaximum}" Value="{Binding SelectedFrame}" VerticalAlignment="Center" IsSnapToTickEnabled="True" TickFrequency="1" SmallChange="1" LargeChange="1"/>
											<StackPanel Grid.Column="2" Orientation="Horizontal" Spacing="8" Margin="8,0,0,0" VerticalAlignment="Center">
												<Button Classes="icon-btn" Classes.selected="{Binding IsAnimationPlaying}" Command="{Binding ToggleAnimationPreviewCommand}" ToolTip.Tip="Play animation loop">
													<Path Data="M8,5 L8,19 L19,12 Z" Fill="#CCCCCC" Width="10" Height="10" Stretch="Uniform"/>
												</Button>
												<TextBlock Text="{Binding FrameDisplay, Mode=OneWay}" Foreground="#AAA" FontSize="11" VerticalAlignment="Center"/>
											</StackPanel>
										</Grid>

										<Grid ColumnDefinitions="70,168,80" IsVisible="{Binding ShowLayerSlider}">
											<TextBlock Grid.Column="0" Text="Layer:" Foreground="#888" FontSize="11" VerticalAlignment="Center" HorizontalAlignment="Right" Margin="0,0,8,0"/>
											<Slider Grid.Column="1" Theme="{StaticResource FlatSliderTheme}" Minimum="0" Maximum="{Binding LayerMaximum}" Value="{Binding SelectedLayer}" VerticalAlignment="Center" IsSnapToTickEnabled="True" TickFrequency="1" SmallChange="1" LargeChange="1"/>
											<TextBlock Grid.Column="2" Text="{Binding LayerDisplay, Mode=OneWay}" Foreground="#AAA" FontSize="11" VerticalAlignment="Center" Margin="8,0,0,0"/>
										</Grid>

										<Grid ColumnDefinitions="70,168,80" IsVisible="{Binding ShowAddonSlider}">
											<TextBlock Grid.Column="0" Text="Addon:" Foreground="#888" FontSize="11" VerticalAlignment="Center" HorizontalAlignment="Right" Margin="0,0,8,0"/>
											<Slider Grid.Column="1" Theme="{StaticResource FlatSliderTheme}" Minimum="0" Maximum="{Binding AddonMaximum}" Value="{Binding ViewPatternYIndex}" VerticalAlignment="Center" IsSnapToTickEnabled="True" TickFrequency="1" SmallChange="1" LargeChange="1"/>
											<TextBlock Grid.Column="2" Text="{Binding PatternYDisplay, Mode=OneWay}" Foreground="#AAA" FontSize="11" VerticalAlignment="Center" Margin="8,0,0,0"/>
										</Grid>

										<Grid ColumnDefinitions="70,168,80" IsVisible="{Binding ShowPatternZSlider}">
											<TextBlock Grid.Column="0" Text="Mount:" Foreground="#888" FontSize="11" VerticalAlignment="Center" HorizontalAlignment="Right" Margin="0,0,8,0"/>
											<Slider Grid.Column="1" Theme="{StaticResource FlatSliderTheme}" Minimum="0" Maximum="{Binding PatternZMaximum}" Value="{Binding ViewPatternZIndex}" VerticalAlignment="Center" IsSnapToTickEnabled="True" TickFrequency="1" SmallChange="1" LargeChange="1"/>
											<TextBlock Grid.Column="2" Text="{Binding PatternZDisplay, Mode=OneWay}" Foreground="#AAA" FontSize="11" VerticalAlignment="Center" Margin="8,0,0,0"/>
										</Grid>

										<StackPanel Orientation="Horizontal" Spacing="16" HorizontalAlignment="Right" Margin="0,2,0,0">
											<ToggleSwitch Content="Show crop size" IsChecked="{Binding ShowCropSize}" OnContent="" OffContent="" FontSize="11"/>
											<ToggleSwitch Content="Show grid" IsChecked="{Binding ShowGrid}" OnContent="" OffContent="" FontSize="11"/>
										</StackPanel>

										<Grid ColumnDefinitions="Auto,120,Auto" IsVisible="{Binding ShowDurationEditors}" HorizontalAlignment="Right" Margin="0,4,0,0">
											<TextBlock Grid.Column="0" Text="Min:" Foreground="#888" FontSize="11" VerticalAlignment="Center" Margin="0,0,8,0"/>
											<NumericUpDown Grid.Column="1" Value="{Binding MinimumDuration}" Minimum="0" Maximum="60000" Width="120" MinWidth="120" Height="28" Padding="4,0" FontSize="11"/>
											<Button Grid.Column="2" Classes="icon-btn" Command="{Binding ApplyDefaultDurationsCommand}" ToolTip.Tip="Default durations" Margin="6,0,0,0">
												<Path Data="M12,4 L12,2 M12,22 L12,20 M4.93,4.93 L6.34,6.34 M17.66,17.66 L19.07,19.07 M4,12 L2,12 M22,12 L20,12 M4.93,19.07 L6.34,17.66 M17.66,6.34 L19.07,4.93 M12,8 A4,4 0 1,1 12,16 A4,4 0 1,1 12,8"
													  Stroke="#CCCCCC" StrokeThickness="1.3" Width="14" Height="14" Stretch="Uniform"/>
											</Button>
										</Grid>

										<Grid ColumnDefinitions="Auto,120,Auto" IsVisible="{Binding ShowDurationEditors}" HorizontalAlignment="Right">
											<TextBlock Grid.Column="0" Text="Max:" Foreground="#888" FontSize="11" VerticalAlignment="Center" Margin="0,0,8,0"/>
											<NumericUpDown Grid.Column="1" Value="{Binding MaximumDuration}" Minimum="0" Maximum="60000" Width="120" MinWidth="120" Height="28" Padding="4,0" FontSize="11"/>
											<Button Grid.Column="2" Classes="icon-btn" Command="{Binding ApplyDurationForAllFramesCommand}" ToolTip.Tip="Set for all frames" Margin="6,0,0,0">
												<Path Data="M4,6 H16 M4,10 H16 M4,14 H16 M4,18 H10" Stroke="#CCCCCC" StrokeThickness="1.3" Width="14" Height="14" Stretch="Uniform"/>
											</Button>
										</Grid>
									</StackPanel>
								</StackPanel>
							</Border>

							<!-- Patterns -->
							<Border Background="#1E1E1E" CornerRadius="6" Padding="12" BorderBrush="#353535" BorderThickness="1" IsVisible="{Binding HasPatterns}">
								<StackPanel Spacing="8" x:CompileBindings="False">
									<TextBlock Text="Patterns" FontWeight="SemiBold" Foreground="#CCCCCC" FontSize="12"/>
									<Grid ColumnDefinitions="Auto,120" RowDefinitions="Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto" HorizontalAlignment="Right">
										<TextBlock Grid.Row="0" Grid.Column="0" Text="Width:" Foreground="#888" FontSize="11" VerticalAlignment="Center" HorizontalAlignment="Right" Margin="0,0,8,4"/>
										<NumericUpDown x:Name="PatternTileWidthNud" Grid.Row="0" Grid.Column="1" Minimum="1" Maximum="32" Increment="1" Width="120" MinWidth="120" Height="28" Padding="4,0" FontSize="11" Margin="0,0,0,4"/>
										<TextBlock Grid.Row="1" Grid.Column="0" Text="Height:" Foreground="#888" FontSize="11" VerticalAlignment="Center" HorizontalAlignment="Right" Margin="0,0,8,4"/>
										<NumericUpDown x:Name="PatternTileHeightNud" Grid.Row="1" Grid.Column="1" Minimum="1" Maximum="32" Increment="1" Width="120" MinWidth="120" Height="28" Padding="4,0" FontSize="11" Margin="0,0,0,4"/>
										<TextBlock Grid.Row="2" Grid.Column="0" Text="Crop Size:" Foreground="#888" FontSize="11" VerticalAlignment="Center" HorizontalAlignment="Right" Margin="0,0,8,4"/>
										<NumericUpDown x:Name="PatternCropSizeNud" Grid.Row="2" Grid.Column="1" Minimum="1" Maximum="64" Increment="1" Width="120" MinWidth="120" Height="28" Padding="4,0" FontSize="11" Margin="0,0,0,4"/>
										<TextBlock Grid.Row="3" Grid.Column="0" Text="Layers:" Foreground="#888" FontSize="11" VerticalAlignment="Center" HorizontalAlignment="Right" Margin="0,0,8,4"/>
										<NumericUpDown x:Name="PatternLayerCountNud" Grid.Row="3" Grid.Column="1" Minimum="1" Maximum="16" Increment="1" Width="120" MinWidth="120" Height="28" Padding="4,0" FontSize="11" Margin="0,0,0,4"/>
										<TextBlock Grid.Row="4" Grid.Column="0" Text="Pattern X:" Foreground="#888" FontSize="11" VerticalAlignment="Center" HorizontalAlignment="Right" Margin="0,0,8,4"/>
										<NumericUpDown x:Name="PatternXCountNud" Grid.Row="4" Grid.Column="1" Minimum="1" Maximum="32" Increment="1" Width="120" MinWidth="120" Height="28" Padding="4,0" FontSize="11" Margin="0,0,0,4"/>
										<TextBlock Grid.Row="5" Grid.Column="0" Text="Pattern Y:" Foreground="#888" FontSize="11" VerticalAlignment="Center" HorizontalAlignment="Right" Margin="0,0,8,4"/>
										<NumericUpDown x:Name="PatternYCountNud" Grid.Row="5" Grid.Column="1" Minimum="1" Maximum="32" Increment="1" Width="120" MinWidth="120" Height="28" Padding="4,0" FontSize="11" Margin="0,0,0,4"/>
										<TextBlock Grid.Row="6" Grid.Column="0" Text="Pattern Z:" Foreground="#888" FontSize="11" VerticalAlignment="Center" HorizontalAlignment="Right" Margin="0,0,8,4"/>
										<NumericUpDown x:Name="PatternZCountNud" Grid.Row="6" Grid.Column="1" Minimum="1" Maximum="16" Increment="1" Width="120" MinWidth="120" Height="28" Padding="4,0" FontSize="11" Margin="0,0,0,4"/>
										<TextBlock Grid.Row="7" Grid.Column="0" Text="Animations:" Foreground="#888" FontSize="11" VerticalAlignment="Center" HorizontalAlignment="Right" Margin="0,0,8,0"/>
										<NumericUpDown x:Name="PatternFrameCountNud" Grid.Row="7" Grid.Column="1" Minimum="1" Maximum="60" Increment="1" Width="120" MinWidth="120" Height="28" Padding="4,0" FontSize="11"/>
									</Grid>
								</StackPanel>
							</Border>

							<!-- Animation -->
							<Border Background="#1E1E1E" CornerRadius="6" Padding="12" BorderBrush="#353535" BorderThickness="1" IsVisible="{Binding ShowAnimationSection}">
								<StackPanel Spacing="8">
									<TextBlock Text="Animation" FontWeight="SemiBold" Foreground="#CCCCCC" FontSize="12"/>
									<StackPanel Spacing="6" HorizontalAlignment="Right">
										<Grid ColumnDefinitions="Auto,170" HorizontalAlignment="Right">
											<TextBlock Grid.Column="0" Text="Mode:" Foreground="#888" FontSize="11" VerticalAlignment="Center" Margin="0,0,8,0"/>
											<ComboBox Grid.Column="1" ItemsSource="{Binding AnimationModes, Mode=OneWay}" SelectedIndex="{Binding SelectedAnimationMode}" FontSize="11"/>
										</Grid>
										<Grid ColumnDefinitions="Auto,170" HorizontalAlignment="Right">
											<TextBlock Grid.Column="0" Text="Frame strategy:" Foreground="#888" FontSize="11" VerticalAlignment="Center" Margin="0,0,8,0"/>
											<ComboBox Grid.Column="1" ItemsSource="{Binding FrameStrategies, Mode=OneWay}" SelectedIndex="{Binding FrameStrategyIndex}" FontSize="11"/>
										</Grid>
										<Grid ColumnDefinitions="Auto,120" IsVisible="{Binding ShowLoopCountEditor}" HorizontalAlignment="Right">
											<TextBlock Grid.Column="0" Text="Loop count:" Foreground="#888" FontSize="11" VerticalAlignment="Center" Margin="0,0,8,0"/>
											<NumericUpDown Grid.Column="1" Value="{Binding AnimationLoopCount}" Minimum="0" Maximum="{Binding LoopCountMaximum}" Width="120" MinWidth="120" Height="28" Padding="4,0" FontSize="11"/>
										</Grid>
										<Grid ColumnDefinitions="Auto,120" HorizontalAlignment="Right">
											<TextBlock Grid.Column="0" Text="Start frame:" Foreground="#888" FontSize="11" VerticalAlignment="Center" Margin="0,0,8,0"/>
											<NumericUpDown Grid.Column="1" Value="{Binding AnimationStartFrame}" Minimum="-1" Maximum="{Binding StartFrameMaximum}" Width="120" MinWidth="120" Height="28" Padding="4,0" FontSize="11"/>
										</Grid>
									</StackPanel>
								</StackPanel>
							</Border>

						</StackPanel>
					</ScrollViewer>
				</TabItem>

				<TabItem Header="Properties">
					<ScrollViewer>
						<StackPanel Spacing="8" Margin="0,8,0,16">
							<!-- Is Ground Section -->
							<Border Background="#1E1E1E" CornerRadius="6" Padding="12" BorderBrush="#353535" BorderThickness="1" IsVisible="{Binding IsItem}">
								<Grid ColumnDefinitions="*, Auto">
									<ToggleSwitch Grid.Column="0" Content="Is Ground" IsChecked="{Binding IsGround}" OnContent="" OffContent="" FontSize="11" VerticalAlignment="Center"/>
									<StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="8" IsEnabled="{Binding IsGround}" VerticalAlignment="Center">
										<TextBlock Text="Ground Speed:" Foreground="#888" FontSize="11" VerticalAlignment="Center"/>
										<NumericUpDown Value="{Binding GroundSpeed}" Minimum="0" Maximum="65535" Width="100" Height="28" Padding="4,0" FontSize="11"/>
									</StackPanel>
								</Grid>
							</Border>

							<!-- Has Light Section -->
							<Border Background="#1E1E1E" CornerRadius="6" Padding="12" BorderBrush="#353535" BorderThickness="1">
								<Grid RowDefinitions="Auto, Auto" ColumnDefinitions="*, Auto">
									<ToggleSwitch Grid.Row="0" Grid.Column="0" Content="Has Light" IsChecked="{Binding HasLight}" OnContent="" OffContent="" FontSize="11" VerticalAlignment="Center"/>
									<StackPanel Grid.Row="0" Grid.Column="1" Orientation="Horizontal" Spacing="8" IsEnabled="{Binding HasLight}" VerticalAlignment="Center" Margin="0,0,0,4">
										<TextBlock Text="Light Color:" Foreground="#888" FontSize="11" VerticalAlignment="Center"/>
										<NumericUpDown Value="{Binding LightColor}" Minimum="0" Maximum="215" Width="100" Height="28" Padding="4,0" FontSize="11"/>
										<Button Width="20" Height="20" Margin="4,0,0,0" BorderBrush="#444" BorderThickness="1" Background="{Binding LightColorBrush, Mode=OneWay}" ToolTip.Tip="Pick Light Color">
											<Button.Flyout>
												<Flyout Placement="BottomEdgeAlignedRight">
													<Border Background="#1E1E1E" BorderBrush="#353535" BorderThickness="1" CornerRadius="4" Padding="6" Width="268" Height="236">
														<ItemsControl ItemsSource="{Binding PaletteColors}">
															<ItemsControl.ItemsPanel>
																<ItemsPanelTemplate>
																	<UniformGrid Columns="16" Rows="14" HorizontalAlignment="Center" VerticalAlignment="Center"/>
																</ItemsPanelTemplate>
															</ItemsControl.ItemsPanel>
															<ItemsControl.ItemTemplate>
																<DataTemplate x:DataType="vm:FloatingThingEditorViewModel+PaletteColor">
																	<Button Width="14" Height="14" Margin="1" Padding="0" CornerRadius="0" BorderThickness="0" Background="{Binding Hex}" Command="{Binding $parent[UserControl].DataContext.SelectLightColorCommand}" CommandParameter="{Binding Index}"/>
																</DataTemplate>
															</ItemsControl.ItemTemplate>
														</ItemsControl>
													</Border>
												</Flyout>
											</Button.Flyout>
										</Button>
									</StackPanel>
									<StackPanel Grid.Row="1" Grid.Column="1" Orientation="Horizontal" Spacing="8" IsEnabled="{Binding HasLight}" VerticalAlignment="Center">
										<TextBlock Text="Light Intensity:" Foreground="#888" FontSize="11" VerticalAlignment="Center"/>
										<NumericUpDown Value="{Binding LightLevel}" Minimum="0" Maximum="255" Width="100" Height="28" Padding="4,0" FontSize="11"/>
										<Border Width="24"/>
									</StackPanel>
								</Grid>
							</Border>

							<!-- Automap Section -->
							<Border Background="#1E1E1E" CornerRadius="6" Padding="12" BorderBrush="#353535" BorderThickness="1" IsVisible="{Binding IsItem}">
								<Grid ColumnDefinitions="*, Auto">
									<ToggleSwitch Grid.Column="0" Content="Automap" IsChecked="{Binding MiniMap}" OnContent="" OffContent="" FontSize="11" VerticalAlignment="Center"/>
									<StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="8" IsEnabled="{Binding MiniMap}" VerticalAlignment="Center">
										<TextBlock Text="Automap Color:" Foreground="#888" FontSize="11" VerticalAlignment="Center"/>
										<NumericUpDown Value="{Binding MiniMapColor}" Minimum="0" Maximum="215" Width="100" Height="28" Padding="4,0" FontSize="11"/>
										<Button Width="20" Height="20" Margin="4,0,0,0" BorderBrush="#444" BorderThickness="1" Background="{Binding MiniMapColorBrush, Mode=OneWay}" ToolTip.Tip="Pick Automap Color">
											<Button.Flyout>
												<Flyout Placement="BottomEdgeAlignedRight">
													<Border Background="#1E1E1E" BorderBrush="#353535" BorderThickness="1" CornerRadius="4" Padding="6" Width="268" Height="236">
														<ItemsControl ItemsSource="{Binding PaletteColors}">
															<ItemsControl.ItemsPanel>
																<ItemsPanelTemplate>
																	<UniformGrid Columns="16" Rows="14" HorizontalAlignment="Center" VerticalAlignment="Center"/>
																</ItemsPanelTemplate>
															</ItemsControl.ItemsPanel>
															<ItemsControl.ItemTemplate>
																<DataTemplate x:DataType="vm:FloatingThingEditorViewModel+PaletteColor">
																	<Button Width="14" Height="14" Margin="1" Padding="0" CornerRadius="0" BorderThickness="0" Background="{Binding Hex}" Command="{Binding $parent[UserControl].DataContext.SelectMiniMapColorCommand}" CommandParameter="{Binding Index}"/>
																</DataTemplate>
															</ItemsControl.ItemTemplate>
														</ItemsControl>
													</Border>
												</Flyout>
											</Button.Flyout>
										</Button>
									</StackPanel>
								</Grid>
							</Border>

							<!-- Has Offset Section -->
							<Border Background="#1E1E1E" CornerRadius="6" Padding="12" BorderBrush="#353535" BorderThickness="1">
								<Grid RowDefinitions="Auto, Auto" ColumnDefinitions="*, Auto">
									<ToggleSwitch Grid.Row="0" Grid.Column="0" Content="Has Offset" IsChecked="{Binding HasOffset}" OnContent="" OffContent="" FontSize="11" VerticalAlignment="Center"/>
									<StackPanel Grid.Row="0" Grid.Column="1" Orientation="Horizontal" Spacing="8" IsEnabled="{Binding HasOffset}" VerticalAlignment="Center" Margin="0,0,0,4">
										<TextBlock Text="Offset X:" Foreground="#888" FontSize="11" VerticalAlignment="Center"/>
										<NumericUpDown Value="{Binding OffsetX}" Minimum="-1024" Maximum="1024" Width="100" Height="28" Padding="4,0" FontSize="11"/>
									</StackPanel>
									<StackPanel Grid.Row="1" Grid.Column="1" Orientation="Horizontal" Spacing="8" IsEnabled="{Binding HasOffset}" VerticalAlignment="Center">
										<TextBlock Text="Offset Y:" Foreground="#888" FontSize="11" VerticalAlignment="Center"/>
										<NumericUpDown Value="{Binding OffsetY}" Minimum="-1024" Maximum="1024" Width="100" Height="28" Padding="4,0" FontSize="11"/>
									</StackPanel>
								</Grid>
							</Border>

							<!-- Has Elevation Section -->
							<Border Background="#1E1E1E" CornerRadius="6" Padding="12" BorderBrush="#353535" BorderThickness="1">
								<Grid ColumnDefinitions="*, Auto">
									<ToggleSwitch Grid.Column="0" Content="Has Elevation" IsChecked="{Binding HasElevation}" OnContent="" OffContent="" FontSize="11" VerticalAlignment="Center"/>
									<StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="8" IsEnabled="{Binding HasElevation}" VerticalAlignment="Center">
										<TextBlock Text="Elevation:" Foreground="#888" FontSize="11" VerticalAlignment="Center"/>
										<NumericUpDown Value="{Binding Elevation}" Minimum="0" Maximum="255" Width="100" Height="28" Padding="4,0" FontSize="11"/>
									</StackPanel>
								</Grid>
							</Border>
							<!-- Market Section -->
							<Border Background="#1E1E1E" CornerRadius="6" Padding="12" BorderBrush="#353535" BorderThickness="1" IsVisible="{Binding ShowMarket}">
								<Grid RowDefinitions="Auto, Auto, Auto, Auto, Auto, Auto" ColumnDefinitions="*, Auto">
									<ToggleSwitch Grid.Row="0" Grid.Column="0" Content="Market" IsChecked="{Binding IsMarketItem}" OnContent="" OffContent="" FontSize="11" VerticalAlignment="Center"/>
									
									<Grid Grid.Row="1" Grid.ColumnSpan="2" ColumnDefinitions="Auto, *" IsEnabled="{Binding IsMarketItem}" Margin="0,6,0,6">
										<TextBlock Grid.Column="0" Text="Name:" Foreground="#888" FontSize="11" VerticalAlignment="Center" Margin="0,0,8,0"/>
										<TextBox Grid.Column="1" Text="{Binding MarketName}" Height="28" Padding="6,4" FontSize="11" Background="#262626" BorderBrush="#3D3D3D"/>
									</Grid>

									<StackPanel Grid.Row="2" Grid.Column="1" Orientation="Horizontal" Spacing="8" IsEnabled="{Binding IsMarketItem}" Margin="0,0,0,4">
										<TextBlock Text="Category:" Foreground="#888" FontSize="11" VerticalAlignment="Center"/>
										<ComboBox ItemsSource="{Binding MarketCategories}" SelectedIndex="{Binding MarketCategoryIndex}" Width="170" Height="28" FontSize="11"/>
									</StackPanel>

									<StackPanel Grid.Row="3" Grid.Column="1" Orientation="Horizontal" Spacing="8" IsEnabled="{Binding IsMarketItem}" Margin="0,0,0,4">
										<TextBlock Text="Trade As:" Foreground="#888" FontSize="11" VerticalAlignment="Center"/>
										<NumericUpDown Value="{Binding MarketTradeAs}" Minimum="0" Maximum="65535" Width="100" Height="28" Padding="4,0" FontSize="11"/>
									</StackPanel>

									<StackPanel Grid.Row="4" Grid.Column="1" Orientation="Horizontal" Spacing="8" IsEnabled="{Binding IsMarketItem}" Margin="0,0,0,4">
										<TextBlock Text="Show As:" Foreground="#888" FontSize="11" VerticalAlignment="Center"/>
										<NumericUpDown Value="{Binding MarketShowAs}" Minimum="0" Maximum="65535" Width="100" Height="28" Padding="4,0" FontSize="11"/>
									</StackPanel>

									<StackPanel Grid.Row="5" Grid.Column="1" Orientation="Horizontal" Spacing="8" IsEnabled="{Binding IsMarketItem}">
										<TextBlock Text="Vocation:" Foreground="#888" FontSize="11" VerticalAlignment="Center" Margin="0,0,4,0"/>
										<NumericUpDown Value="{Binding MarketRestrictProfession}" Minimum="0" Maximum="65535" Width="100" Height="28" Padding="4,0" FontSize="11" Margin="0,0,8,0"/>
										<TextBlock Text="Level:" Foreground="#888" FontSize="11" VerticalAlignment="Center"/>
										<NumericUpDown Value="{Binding MarketRestrictLevel}" Minimum="0" Maximum="65535" Width="100" Height="28" Padding="4,0" FontSize="11"/>
									</StackPanel>
								</Grid>
							</Border>

							<!-- Write / Read Section -->
							<Border Background="#1E1E1E" CornerRadius="6" Padding="12" BorderBrush="#353535" BorderThickness="1" IsVisible="{Binding IsItem}">
								<StackPanel Spacing="6">
									<TextBlock Text="Write / Read" FontWeight="SemiBold" Foreground="#CCCCCC" FontSize="12" Margin="0,0,0,6"/>
									<Grid ColumnDefinitions="*, Auto" RowDefinitions="Auto, Auto, Auto">
										<ToggleSwitch Grid.Row="0" Grid.Column="0" Content="Writable" IsChecked="{Binding Writable}" OnContent="" OffContent="" FontSize="11" VerticalAlignment="Center"/>
										<ToggleSwitch Grid.Row="1" Grid.Column="0" Content="Writable Once" IsChecked="{Binding WritableOnce}" OnContent="" OffContent="" FontSize="11" VerticalAlignment="Center"/>
										<StackPanel Grid.Row="2" Grid.Column="1" Orientation="Horizontal" Spacing="8" VerticalAlignment="Center" IsEnabled="{Binding Writable}">
											<TextBlock Text="Max Length:" Foreground="#888" FontSize="11" VerticalAlignment="Center"/>
											<NumericUpDown Value="{Binding MaxTextLength}" Minimum="0" Maximum="65535" Width="100" Height="28" Padding="4,0" FontSize="11"/>
										</StackPanel>
									</Grid>
								</StackPanel>
							</Border>
							<!-- Has Action Section -->
							<Border Background="#1E1E1E" CornerRadius="6" Padding="12" BorderBrush="#353535" BorderThickness="1" IsVisible="{Binding ShowHasDefaultAction}">
								<Grid ColumnDefinitions="*, Auto">
									<ToggleSwitch Grid.Column="0" Content="Has Action" IsChecked="{Binding HasDefaultAction}" OnContent="" OffContent="" FontSize="11" VerticalAlignment="Center"/>
									<StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="8" IsEnabled="{Binding HasDefaultAction}" VerticalAlignment="Center">
										<TextBlock Text="Action Type:" Foreground="#888" FontSize="11" VerticalAlignment="Center"/>
										<ComboBox ItemsSource="{Binding DefaultActions}" SelectedIndex="{Binding DefaultActionIndex}" Width="170" Height="28" FontSize="11"/>
									</StackPanel>
								</Grid>
							</Border>

							<!-- Lens Help Section -->
							<Border Background="#1E1E1E" CornerRadius="6" Padding="12" BorderBrush="#353535" BorderThickness="1" IsVisible="{Binding IsItem}">
								<Grid ColumnDefinitions="*, Auto">
									<ToggleSwitch Grid.Column="0" Content="Lens Help" IsChecked="{Binding IsLensHelp}" OnContent="" OffContent="" FontSize="11" VerticalAlignment="Center"/>
									<StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="8" IsEnabled="{Binding IsLensHelp}" VerticalAlignment="Center">
										<TextBlock Text="Type:" Foreground="#888" FontSize="11" VerticalAlignment="Center"/>
										<ComboBox ItemsSource="{Binding LensHelpTypes}" SelectedIndex="{Binding LensHelpIndex}" Width="170" Height="28" FontSize="11"/>
									</StackPanel>
								</Grid>
							</Border>
						</StackPanel>
					</ScrollViewer>
				</TabItem>

				<TabItem Header="Flags">
					<ScrollViewer>
						<StackPanel Spacing="8" Margin="0,8,0,16">
							<!-- DAT File Flags -->
							<Border Background="#1E1E1E" CornerRadius="6" Padding="12" BorderBrush="#353535" BorderThickness="1" IsVisible="{Binding IsDat}">
								<StackPanel Spacing="8">
									<TextBlock Text="Flags" FontWeight="SemiBold" Foreground="#CCCCCC" FontSize="12" Margin="0,0,0,6"/>
									<Grid ColumnDefinitions="*, *">
										<!-- Left Column -->
										<StackPanel Grid.Column="0" Spacing="6" Margin="0,0,10,0">
											<!-- Radio buttons group -->
											<StackPanel Spacing="2" IsEnabled="{Binding !IsGround}" Margin="0,0,0,8">
												<RadioButton Content="Common" IsChecked="{Binding IsFlagsCommon}" FontSize="11"/>
												<RadioButton Content="Ground Border" IsChecked="{Binding IsFlagsGroundBorder}" IsVisible="{Binding ShowGroundBorder}" FontSize="11"/>
												<RadioButton Content="Bottom" IsChecked="{Binding IsFlagsBottom}" FontSize="11"/>
												<RadioButton Content="Top" IsChecked="{Binding IsFlagsTop}" FontSize="11"/>
											</StackPanel>

											<ToggleSwitch Content="Container" IsChecked="{Binding IsContainer}" OnContent="" OffContent="" FontSize="11"/>
											<ToggleSwitch Content="Stackable" IsChecked="{Binding Stackable}" IsVisible="{Binding IsItem}" OnContent="" OffContent="" FontSize="11"/>
											<ToggleSwitch Content="Force Use" IsChecked="{Binding ForceUse}" OnContent="" OffContent="" FontSize="11"/>
											<ToggleSwitch Content="Multi Use" IsChecked="{Binding MultiUse}" OnContent="" OffContent="" FontSize="11"/>
											<ToggleSwitch Content="Fluid Container" IsChecked="{Binding IsFluidContainer}" OnContent="" OffContent="" FontSize="11"/>
											<ToggleSwitch Content="Fluid" IsChecked="{Binding IsFluid}" OnContent="" OffContent="" FontSize="11"/>
											<ToggleSwitch Content="Unpassable" IsChecked="{Binding IsUnpassable}" OnContent="" OffContent="" FontSize="11"/>
											<ToggleSwitch Content="Unmoveable" IsChecked="{Binding IsUnmoveable}" OnContent="" OffContent="" FontSize="11"/>
											<ToggleSwitch Content="Block Missile" IsChecked="{Binding BlockMissile}" IsVisible="{Binding !IsMissile}" OnContent="" OffContent="" FontSize="11"/>
											<ToggleSwitch Content="Block Pathfinder" IsChecked="{Binding BlockPathfind}" OnContent="" OffContent="" FontSize="11"/>
											<ToggleSwitch Content="Floor Change" IsChecked="{Binding FloorChange}" OnContent="" OffContent="" FontSize="11"/>
										</StackPanel>

										<!-- Right Column -->
										<StackPanel Grid.Column="1" Spacing="6" Margin="10,0,0,0">
											<ToggleSwitch Content="No Move Animation" IsChecked="{Binding NoMoveAnimation}" IsVisible="{Binding ShowNoMoveAnimation}" OnContent="" OffContent="" FontSize="11"/>
											<ToggleSwitch Content="Pickupable" IsChecked="{Binding Pickupable}" OnContent="" OffContent="" FontSize="11"/>
											<ToggleSwitch Content="Hangable" IsChecked="{Binding Hangable}" IsVisible="{Binding ShowHangable}" OnContent="" OffContent="" FontSize="11"/>
											<ToggleSwitch Content="Hook East" IsChecked="{Binding IsHorizontal}" IsVisible="{Binding ShowIsHorizontal}" OnContent="" OffContent="" FontSize="11"/>
											<ToggleSwitch Content="Hook South" IsChecked="{Binding IsVertical}" IsVisible="{Binding ShowIsVertical}" OnContent="" OffContent="" FontSize="11"/>
											<ToggleSwitch Content="Rotatable" IsChecked="{Binding Rotatable}" IsVisible="{Binding IsItem}" OnContent="" OffContent="" FontSize="11"/>
											<ToggleSwitch Content="Don't Hide" IsChecked="{Binding DontHide}" IsVisible="{Binding ShowDontHide}" OnContent="" OffContent="" FontSize="11"/>
											<ToggleSwitch Content="Translucent" IsChecked="{Binding IsTranslucent}" IsVisible="{Binding ShowIsTranslucent}" OnContent="" OffContent="" FontSize="11"/>
											<ToggleSwitch Content="Lying Object" IsChecked="{Binding IsLyingObject}" OnContent="" OffContent="" FontSize="11"/>
											<ToggleSwitch Content="Full Ground" IsChecked="{Binding IsFullGround}" OnContent="" OffContent="" FontSize="11"/>
											<ToggleSwitch Content="Ignore Look" IsChecked="{Binding IgnoreLook}" IsVisible="{Binding ShowIgnoreLook}" OnContent="" OffContent="" FontSize="11"/>
											<ToggleSwitch Content="Useable" IsChecked="{Binding Usable}" IsVisible="{Binding ShowUsable}" OnContent="" OffContent="" FontSize="11"/>
											<ToggleSwitch Content="Wrappable" IsChecked="{Binding Wrappable}" IsVisible="{Binding ShowWrappable}" OnContent="" OffContent="" FontSize="11"/>
											<ToggleSwitch Content="Unwrappable" IsChecked="{Binding Unwrappable}" IsVisible="{Binding ShowUnwrappable}" OnContent="" OffContent="" FontSize="11"/>
											<ToggleSwitch Content="Bottom Effect" IsChecked="{Binding BottomEffect}" IsVisible="{Binding ShowBottomEffect}" OnContent="" OffContent="" FontSize="11"/>
										</StackPanel>
									</Grid>
								</StackPanel>
							</Border>

							<!-- JSON Custom Flags -->
							<Border Background="#1E1E1E" CornerRadius="6" Padding="12" BorderBrush="#353535" BorderThickness="1" IsVisible="{Binding IsJson}">
								<StackPanel Spacing="8">
									<TextBlock Text="JSON Custom Flags" FontWeight="SemiBold" Foreground="#CCCCCC" FontSize="12" Margin="0,0,0,6"/>
									<!-- Add custom flag input -->
									<Grid ColumnDefinitions="*, Auto" Margin="0,0,0,8">
										<TextBox Grid.Column="0" Text="{Binding NewFlagName}" PlaceholderText="New flag name..." Height="28" Padding="6,4" FontSize="11" Background="#262626" BorderBrush="#3D3D3D"/>
										<Button Grid.Column="1" Content="Add Flag" Command="{Binding AddCustomFlagCommand}" Margin="8,0,0,0" FontSize="11" Height="28" Padding="12,0" Background="#3A7BD5" Foreground="White"/>
									</Grid>

									<TextBlock Text="Possible Flags:" Foreground="#888" FontSize="11" Margin="0,4,0,2"/>
									<Border Background="#262626" BorderBrush="#3D3D3D" BorderThickness="1" CornerRadius="4" Height="200">
										<ScrollViewer>
											<ItemsControl ItemsSource="{Binding CustomFlags}">
												<ItemsControl.ItemTemplate>
													<DataTemplate x:DataType="vm:CustomFlagViewModel">
														<Grid ColumnDefinitions="*, Auto" Margin="6,1">
															<CheckBox Grid.Column="0" Content="{Binding Name}" IsChecked="{Binding IsChecked}" FontSize="11" VerticalAlignment="Center"/>
															<Button Grid.Column="1" Content="Delete" Command="{Binding RemoveCommand}" FontSize="10" Background="#D9534F" Foreground="White" Padding="6,2" Height="20" VerticalAlignment="Center"/>
														</Grid>
													</DataTemplate>
												</ItemsControl.ItemTemplate>
											</ItemsControl>
										</ScrollViewer>
									</Border>
								</StackPanel>
							</Border>
						</StackPanel>
					</ScrollViewer>
				</TabItem>
			</TabControl>
			<!-- Resize handles -->
			<Border Grid.RowSpan="3" Name="ResizeLeft" Width="5" HorizontalAlignment="Left" Background="Transparent" Cursor="SizeWestEast"
					IsVisible="{Binding ShowResizeHandles}"/>
			<Border Grid.RowSpan="3" Name="ResizeRight" Width="5" HorizontalAlignment="Right" Background="Transparent" Cursor="SizeWestEast"
					IsVisible="{Binding ShowResizeHandles}"/>
			<Border Grid.Row="2" Name="ResizeBottom" Height="5" VerticalAlignment="Bottom" Background="Transparent" Cursor="SizeNorthSouth"
					IsVisible="{Binding ShowResizeHandles}"/>
			<Border Grid.Row="2" Name="ResizeCorner" Width="10" Height="10" HorizontalAlignment="Right" VerticalAlignment="Bottom" Background="Transparent" Cursor="BottomRightCorner"
					IsVisible="{Binding ShowResizeHandles}"/>
			<Border Grid.Row="2" Name="ResizeBottomLeft" Width="10" Height="10" HorizontalAlignment="Left" VerticalAlignment="Bottom" Background="Transparent" Cursor="BottomLeftCorner"
					IsVisible="{Binding ShowResizeHandles}"/>

			<!-- Footer with Save & Cancel Buttons -->
			<Border Grid.Row="2" Background="#2D2D2D" BorderBrush="#3C3C3C" BorderThickness="0,1,0,0" Height="44" Padding="12,0" IsVisible="{Binding !IsMinimized}">
				<Grid ColumnDefinitions="*, Auto, Auto">
					<StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
						<Button Content="Cancel" Command="{Binding CancelCommand}" IsEnabled="{Binding CanCancel}" Width="80" Height="26" HorizontalContentAlignment="Center" VerticalContentAlignment="Center" FontSize="11" Background="#3D3D3D" Foreground="#E0E0E0"/>
						<Button Content="Save" Command="{Binding SaveCommand}" IsEnabled="{Binding CanSave}" Width="80" Height="26" HorizontalContentAlignment="Center" VerticalContentAlignment="Center" FontSize="11" Background="#3A7BD5" Foreground="White"/>
					</StackPanel>
				</Grid>
			</Border>

			<Border Grid.RowSpan="3" Background="#B0000000" IsVisible="{Binding ShowAddSpriteConfirmation}" CornerRadius="8">
				<Border Background="#2A2A2A" BorderBrush="#444444" BorderThickness="1" CornerRadius="8" Padding="16" Width="380" HorizontalAlignment="Center" VerticalAlignment="Center" BoxShadow="0 4 12 0 #7F000000">
					<StackPanel Spacing="12">
						<TextBlock Text="Add sprite?" FontWeight="Bold" Foreground="#FFFFFF" HorizontalAlignment="Center" FontSize="13"/>
						<TextBlock Text="{Binding AddSpriteConfirmationText, Mode=OneWay}" FontSize="11" Foreground="#CCCCCC" TextWrapping="Wrap"/>
						<Grid ColumnDefinitions="*, *" Margin="0,8,0,0">
							<Button Grid.Column="0" Content="Cancel" Command="{Binding CancelAddSpriteCommand}" Margin="0,0,4,0" HorizontalAlignment="Stretch" HorizontalContentAlignment="Center" FontSize="11" Padding="0,6"/>
							<Button Grid.Column="1" Content="Add sprite" Command="{Binding ConfirmAddSpriteCommand}" Background="#3A7BD5" Foreground="White" Margin="4,0,0,0" HorizontalAlignment="Stretch" HorizontalContentAlignment="Center" FontSize="11" Padding="0,6"/>
						</Grid>
					</StackPanel>
				</Border>
			</Border>

			<!-- Navigation Prompt Overlay -->
			<Border Grid.RowSpan="3" Background="#B0000000" IsVisible="{Binding ShowPromptOverlay}" CornerRadius="8">
				<Border Background="#2A2A2A" BorderBrush="#444444" BorderThickness="1" CornerRadius="8" Padding="16" Width="380" HorizontalAlignment="Center" VerticalAlignment="Center" BoxShadow="0 4 12 0 #7F000000">
					<StackPanel Spacing="12">
						<TextBlock Text="{Binding PromptTitle}" FontWeight="Bold" Foreground="#FFFFFF" HorizontalAlignment="Center" FontSize="13"/>
						<TextBlock Text="{Binding PromptText}" FontSize="11" Foreground="#CCCCCC" TextWrapping="Wrap" HorizontalAlignment="Center"/>
						<Grid ColumnDefinitions="*, *, *" Margin="0,8,0,0">
							<Button Grid.Column="0" Content="Save" Command="{Binding PromptSaveCommand}" Background="#3A7BD5" Foreground="White" Margin="0,0,4,0" HorizontalAlignment="Stretch" HorizontalContentAlignment="Center" FontSize="11" Padding="0,6"/>
							<Button Grid.Column="1" Content="Don't Save" Command="{Binding PromptDontSaveCommand}" Margin="4,0,4,0" HorizontalAlignment="Stretch" HorizontalContentAlignment="Center" FontSize="11" Padding="0,6"/>
							<Button Grid.Column="2" Content="Cancel" Command="{Binding PromptCancelCommand}" Margin="4,0,0,0" HorizontalAlignment="Stretch" HorizontalContentAlignment="Center" FontSize="11" Padding="0,6"/>
						</Grid>
					</StackPanel>
				</Border>
			</Border>
		</Grid>
	</Border>
</UserControl>
