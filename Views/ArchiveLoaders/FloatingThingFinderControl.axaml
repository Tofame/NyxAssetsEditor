<UserControl xmlns="https://github.com/avaloniaui"
			 xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
			 xmlns:vm="using:NyxAssetsEditor.ViewModels.ArchiveLoaders"
			 xmlns:local="using:NyxAssetsEditor.Views.ArchiveLoaders"
			 x:Class="NyxAssetsEditor.Views.ArchiveLoaders.FloatingThingFinderControl"
			 x:DataType="vm:FloatingThingFinderViewModel"
			 x:CompileBindings="False"
			 Width="{Binding DisplayWidth}">
	<UserControl.Styles>
		<Style Selector="Button.kind-tab">
			<Setter Property="Background" Value="Transparent"/><Setter Property="BorderThickness" Value="0,0,0,2"/>
			<Setter Property="BorderBrush" Value="Transparent"/><Setter Property="Foreground" Value="#888"/>
			<Setter Property="CornerRadius" Value="0"/><Setter Property="Padding" Value="12,7"/>
		</Style>
		<Style Selector="Button.kind-tab.selected">
			<Setter Property="Foreground" Value="#EEE"/><Setter Property="BorderBrush" Value="#5E94FF"/><Setter Property="FontWeight" Value="SemiBold"/>
		</Style>
		<Style Selector="Border.result-tile">
			<Setter Property="BorderBrush" Value="#353535"/><Setter Property="BorderThickness" Value="1"/>
		</Style>
		<Style Selector="TextBlock.label"><Setter Property="Foreground" Value="#999"/><Setter Property="FontSize" Value="11"/></Style>
	</UserControl.Styles>
	<UserControl.Resources>
		<DataTemplate x:Key="FinderFieldTemplate" x:DataType="vm:ThingFinderFieldViewModel">
			<local:BatchApplyField PropertyName="{Binding Descriptor.Key}" IsApplied="{Binding IsActive, Mode=TwoWay}"
				AlwaysShowApply="True" ApplyToolTip="Use this field as a filter" Margin="0,1">
				<Grid ColumnDefinitions="170,*" MinHeight="30">
					<ToggleSwitch Grid.ColumnSpan="2" Content="{Binding DisplayName}" IsChecked="{Binding BooleanValue}"
						OnContent="" OffContent="" FontSize="11" VerticalAlignment="Center" IsVisible="{Binding IsBoolean}"/>
					<TextBlock Text="{Binding DisplayName, StringFormat='{}{0}:'}" Foreground="#888" FontSize="11" VerticalAlignment="Center" IsVisible="{Binding UsesValue}"/>
					<NumericUpDown Grid.Column="1" Value="{Binding NumericValue}"
						Minimum="{Binding NumericMinimum}" Maximum="{Binding NumericMaximum}" Increment="{Binding NumericIncrement}"
						FormatString="0" ParsingNumberStyle="Integer" ClipValueToMinMax="True"
						Height="28" MinWidth="150" Padding="4,0" FontSize="11" IsVisible="{Binding IsInteger}"/>
					<NumericUpDown Grid.Column="1" Value="{Binding NumericValue}"
						Minimum="{Binding NumericMinimum}" Maximum="{Binding NumericMaximum}" Increment="{Binding NumericIncrement}"
						FormatString="0.###" ParsingNumberStyle="Number" ClipValueToMinMax="True"
						Height="28" MinWidth="150" Padding="4,0" FontSize="11" IsVisible="{Binding IsDecimal}"/>
					<ComboBox Grid.Column="1" ItemsSource="{Binding Options}" SelectedItem="{Binding SelectedOption}" PlaceholderText="Select value"
						Height="28" MinWidth="150" FontSize="11" IsVisible="{Binding IsChoice}"/>
					<TextBox Grid.Column="1" Text="{Binding Value, UpdateSourceTrigger=PropertyChanged}" PlaceholderText="Enter value"
						Height="28" MinWidth="150" Padding="6,4" FontSize="11" IsVisible="{Binding UsesTextValue}"/>
				</Grid>
			</local:BatchApplyField>
		</DataTemplate>
	</UserControl.Resources>

	<Border Background="#252525" BorderBrush="#3C3C3C" BorderThickness="1" CornerRadius="8" BoxShadow="0 4 12 0 #7F000000">
		<Grid RowDefinitions="Auto,*">
			<Border Grid.Row="0" Name="TitleBar" Background="#2D2D2D" Height="36" Padding="12,0,6,0">
				<Border.ContextMenu>
					<ContextMenu>
						<MenuItem Header="Undock" Command="{Binding UndockCommand}" IsVisible="{Binding !IsFloating}"/>
						<MenuItem Header="Dock Left" Command="{Binding SetDockStateCommand}" CommandParameter="Left" IsVisible="{Binding IsFloating}"/>
						<MenuItem Header="Dock Center" Command="{Binding SetDockStateCommand}" CommandParameter="Center" IsVisible="{Binding IsFloating}"/>
						<MenuItem Header="Dock Right" Command="{Binding SetDockStateCommand}" CommandParameter="Right" IsVisible="{Binding IsFloating}"/>
						<Separator/><MenuItem Header="Close" Command="{Binding ClosePanelCommand}"/>
					</ContextMenu>
				</Border.ContextMenu>
				<Grid ColumnDefinitions="*,Auto,Auto">
					<TextBlock Text="{Binding Title}" Foreground="#EEE" FontWeight="SemiBold" VerticalAlignment="Center" TextTrimming="CharacterEllipsis"/>
					<Button Grid.Column="1" Content="—" Command="{Binding ToggleMinimizeCommand}" Width="26" Height="26" Padding="0" Background="Transparent" Foreground="#CCC"/>
					<Button Grid.Column="2" Content="&#x00D7;" Command="{Binding ClosePanelCommand}" Width="26" Height="26" Padding="0" Background="Transparent" Foreground="#CCC" HorizontalContentAlignment="Center" VerticalContentAlignment="Center"/>
				</Grid>
			</Border>

			<Grid Grid.Row="1" RowDefinitions="Auto,*,Auto" Height="{Binding DisplayHeight}" IsVisible="{Binding !IsMinimized}">
				<Border Grid.Row="0" BorderBrush="#383838" BorderThickness="0,0,0,1" Background="#282828">
					<StackPanel Orientation="Horizontal">
						<Button Classes="kind-tab" Classes.selected="{Binding IsItemsKind}" Content="Items" Command="{Binding SelectItemsKindCommand}"/>
						<Button Classes="kind-tab" Classes.selected="{Binding IsOutfitsKind}" Content="Outfits" Command="{Binding SelectOutfitsKindCommand}"/>
						<Button Classes="kind-tab" Classes.selected="{Binding IsEffectsKind}" Content="Effects" Command="{Binding SelectEffectsKindCommand}"/>
						<Button Classes="kind-tab" Classes.selected="{Binding IsMissilesKind}" Content="Missiles" Command="{Binding SelectMissilesKindCommand}"/>
					</StackPanel>
				</Border>

				<Grid Grid.Row="1" ColumnDefinitions="470,*" MinWidth="860">
					<Border Grid.Column="0" BorderBrush="#383838" BorderThickness="0,0,1,0" Padding="12">
						<Grid RowDefinitions="*,Auto">
							<ScrollViewer Grid.Row="0" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
								<StackPanel Spacing="8" Margin="0,0,5,0">
					<TextBlock Text="Check a field to use it as a filter." Classes="label" Margin="2,0,0,1"/>
									<Border Background="#1E1E1E" CornerRadius="6" Padding="10" BorderBrush="#353535" BorderThickness="1">
										<StackPanel Spacing="5">
											<TextBlock Text="Properties" FontWeight="SemiBold" Foreground="#CCC" FontSize="12"/>
											<ItemsControl ItemsSource="{Binding PropertyFields}" ItemTemplate="{StaticResource FinderFieldTemplate}"/>
										</StackPanel>
									</Border>

									<Border Background="#1E1E1E" CornerRadius="6" Padding="10" BorderBrush="#353535" BorderThickness="1">
										<StackPanel Spacing="5">
											<TextBlock Text="Flags" FontWeight="SemiBold" Foreground="#CCC" FontSize="12"/>
											<ItemsControl ItemsSource="{Binding FlagFields}" ItemTemplate="{StaticResource FinderFieldTemplate}">
												<ItemsControl.ItemsPanel>
													<ItemsPanelTemplate><UniformGrid Columns="2"/></ItemsPanelTemplate>
												</ItemsControl.ItemsPanel>
											</ItemsControl>
										</StackPanel>
									</Border>

									<Border Background="#1E1E1E" CornerRadius="6" Padding="10" BorderBrush="#353535" BorderThickness="1">
										<StackPanel Spacing="5">
											<Grid ColumnDefinitions="*,Auto">
												<TextBlock Text="Patterns" FontWeight="SemiBold" Foreground="#CCC" FontSize="12" VerticalAlignment="Center"/>
												<StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="6">
													<TextBlock Text="Frame group" Classes="label" VerticalAlignment="Center"/>
													<NumericUpDown Value="{Binding FrameGroupIndex}" Minimum="0" Maximum="255" Increment="1" FormatString="0" Width="65" Height="26" Padding="4,0"/>
												</StackPanel>
											</Grid>
											<ItemsControl ItemsSource="{Binding PatternFields}" ItemTemplate="{StaticResource FinderFieldTemplate}"/>
										</StackPanel>
									</Border>

									<Border Background="#1E1E1E" CornerRadius="6" Padding="10" BorderBrush="#353535" BorderThickness="1" IsVisible="{Binding HasExtraPropertyFields}">
										<StackPanel Spacing="5">
											<TextBlock Text="JSON Custom Flags" FontWeight="SemiBold" Foreground="#CCC" FontSize="12"/>
											<ItemsControl ItemsSource="{Binding ExtraPropertyFields}" ItemTemplate="{StaticResource FinderFieldTemplate}">
												<ItemsControl.ItemsPanel>
													<ItemsPanelTemplate><UniformGrid Columns="2"/></ItemsPanelTemplate>
												</ItemsControl.ItemsPanel>
											</ItemsControl>
										</StackPanel>
									</Border>
								</StackPanel>
							</ScrollViewer>
							<Button Grid.Row="1" Content="Clear filters" Command="{Binding ClearFiltersCommand}" Padding="12,5" HorizontalAlignment="Right" Margin="0,8,0,0"/>
						</Grid>
					</Border>

					<Grid Grid.Column="1" RowDefinitions="Auto,*">
						<Border Grid.Row="0" BorderBrush="#383838" BorderThickness="0,0,0,1" Padding="12,8">
							<TextBlock Text="{Binding ResultCount, StringFormat='{}{0} results'}" Foreground="#AAA" FontSize="11"/>
						</Border>
						<ListBox Grid.Row="1" ItemsSource="{Binding PagedResults}" Background="Transparent" BorderThickness="0" Padding="8" IsVisible="{Binding HasResults}" ScrollViewer.HorizontalScrollBarVisibility="Disabled">
							<ListBox.ItemsPanel>
								<ItemsPanelTemplate>
									<WrapPanel Orientation="Horizontal" HorizontalAlignment="Center"/>
								</ItemsPanelTemplate>
							</ListBox.ItemsPanel>
							<ListBox.Styles>
								<Style Selector="ListBoxItem">
									<Setter Property="Padding" Value="0"/>
									<Setter Property="Background" Value="Transparent"/>
								</Style>
							</ListBox.Styles>
							<ListBox.ItemTemplate>
								<DataTemplate x:DataType="vm:ThingFinderResultViewModel">
									<Border Classes="result-tile" Background="#2A2A2A" CornerRadius="6" Padding="8" Margin="4"
											Width="{Binding $parent[UserControl].DataContext.SourcePanel.GridTileWidth}"
											Height="{Binding $parent[UserControl].DataContext.SourcePanel.GridTileHeight}"
											ToolTip.Tip="{Binding MatchDetails}" ContextRequested="OnResultContextRequested">
										<StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
											<Image Source="{Binding PreviewImage}"
												   Width="{Binding $parent[UserControl].DataContext.SourcePanel.AssetDisplaySize}"
												   Height="{Binding $parent[UserControl].DataContext.SourcePanel.AssetDisplaySize}"
												   Stretch="Uniform" RenderOptions.BitmapInterpolationMode="None" HorizontalAlignment="Center" VerticalAlignment="Center"/>
											<TextBlock Text="{Binding DisplayedId}" FontSize="10" Foreground="#888888" HorizontalAlignment="Center" Margin="0,6,0,0"/>
										</StackPanel>
									</Border>
								</DataTemplate>
							</ListBox.ItemTemplate>
						</ListBox>
						<StackPanel Grid.Row="1" IsVisible="{Binding HasNoResults}" HorizontalAlignment="Center" VerticalAlignment="Center" Spacing="5">
							<TextBlock Text="No matching things" Foreground="#999" FontSize="13"/>
							<TextBlock Text="Change or clear filters to broaden the search." Foreground="#666" FontSize="10"/>
						</StackPanel>
					</Grid>
				</Grid>

				<Border Grid.Row="2" Background="#2D2D2D" BorderBrush="#3C3C3C" BorderThickness="0,1,0,0" Padding="10,7">
					<StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Spacing="8">
						<Button Content="&lt;" Command="{Binding PreviousPageCommand}" IsEnabled="{Binding HasPreviousPage}" Padding="10,3"/>
						<TextBlock Text="Page" Foreground="#888" VerticalAlignment="Center"/>
						<TextBlock Text="{Binding CurrentPage}" Foreground="#EEE" FontWeight="SemiBold" VerticalAlignment="Center"/>
						<TextBlock Text="of" Foreground="#888" VerticalAlignment="Center"/>
						<TextBlock Text="{Binding TotalPages}" Foreground="#EEE" FontWeight="SemiBold" VerticalAlignment="Center"/>
						<Button Content="&gt;" Command="{Binding NextPageCommand}" IsEnabled="{Binding HasNextPage}" Padding="10,3"/>
					</StackPanel>
				</Border>

				<Border Grid.RowSpan="3" Background="#B0000000" IsVisible="{Binding ShowConfirmation}" CornerRadius="8" ZIndex="200">
					<Border Background="#2A2A2A" BorderBrush="#444" BorderThickness="1" CornerRadius="8" Padding="18" Width="400" HorizontalAlignment="Center" VerticalAlignment="Center">
						<StackPanel Spacing="12">
							<TextBlock Text="{Binding ConfirmationTitle}" Foreground="#FFF" FontWeight="SemiBold" FontSize="14" HorizontalAlignment="Center"/>
							<TextBlock Text="{Binding ConfirmationMessage}" Foreground="#CCC" FontSize="11" TextWrapping="Wrap" TextAlignment="Center"/>
							<Grid ColumnDefinitions="*,*" ColumnSpacing="8" Margin="0,6,0,0">
								<Button Content="Cancel" Command="{Binding CancelContextActionCommand}" HorizontalAlignment="Stretch" HorizontalContentAlignment="Center"/>
								<Button Grid.Column="1" Content="{Binding ConfirmationButtonText}" Command="{Binding ConfirmContextActionCommand}" Background="#3A7BD5" Foreground="White" HorizontalAlignment="Stretch" HorizontalContentAlignment="Center"/>
							</Grid>
						</StackPanel>
					</Border>
				</Border>

				<Border Name="ResizeLeft" Grid.RowSpan="3" Width="5" HorizontalAlignment="Left" Background="Transparent" IsVisible="{Binding ShowResizeHandles}" Cursor="SizeWestEast"/>
				<Border Name="ResizeRight" Grid.RowSpan="3" Width="5" HorizontalAlignment="Right" Background="Transparent" IsVisible="{Binding ShowResizeHandles}" Cursor="SizeWestEast"/>
				<Border Name="ResizeBottom" Grid.RowSpan="3" Height="5" VerticalAlignment="Bottom" Background="Transparent" IsVisible="{Binding ShowResizeHandles}" Cursor="SizeNorthSouth"/>
				<Border Name="ResizeCorner" Grid.RowSpan="3" Width="10" Height="10" HorizontalAlignment="Right" VerticalAlignment="Bottom" Background="Transparent" IsVisible="{Binding ShowResizeHandles}" Cursor="BottomRightCorner"/>
			</Grid>
		</Grid>
	</Border>
</UserControl>
