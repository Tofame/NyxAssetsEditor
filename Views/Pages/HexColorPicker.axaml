<UserControl xmlns="https://github.com/avaloniaui"
			 xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
			 x:Class="NyxAssetsEditor.Views.Pages.HexColorPicker">
	<StackPanel Orientation="Horizontal" Spacing="8">
		<ColorPicker Name="ColorBtn" Width="40" Height="28" VerticalAlignment="Center"/>
		<TextBlock Name="HexText" VerticalAlignment="Center" FontSize="11" Foreground="#CCCCCC" Width="70"/>
	</StackPanel>
</UserControl>
