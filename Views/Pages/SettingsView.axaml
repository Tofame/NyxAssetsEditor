<UserControl xmlns="https://github.com/avaloniaui"
			 xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
			 xmlns:vm="using:NyxAssetsEditor.ViewModels.Pages"
			 xmlns:local="using:NyxAssetsEditor.Views.Pages"
			 x:Class="NyxAssetsEditor.Views.Pages.SettingsView"
			 x:DataType="vm:SettingsViewModel">
	<ScrollViewer>
		<StackPanel Margin="30" Spacing="15">
			<TextBlock Text="{Binding Title, Mode=OneWay}" FontSize="28" FontWeight="Bold" Foreground="#FF6B6B"/>
			<TextBlock Text="{Binding Description, Mode=OneWay}" FontSize="14" Foreground="#888888" TextWrapping="Wrap"/>

			<!-- General Section -->
			<Border Background="#1E1E1E" CornerRadius="8" Padding="20" Margin="0,10,0,0">
				<StackPanel Spacing="15">
					<TextBlock Text="General" FontSize="18" FontWeight="SemiBold" Foreground="#FFFFFF"/>
					<StackPanel Orientation="Horizontal" Spacing="10" VerticalAlignment="Center">
						<TextBlock Text="Asset Display Size:" VerticalAlignment="Center" Foreground="#CCCCCC" Width="160"/>
						<ComboBox SelectedIndex="{Binding SelectedDisplaySizeIndex}" Width="120" Height="28">
							<ComboBoxItem Content="32x32"/>
							<ComboBoxItem Content="64x64"/>
							<ComboBoxItem Content="96x96"/>
							<ComboBoxItem Content="128x128"/>
						</ComboBox>
						<TextBlock Text="Display size of things and sprites on the loader panels (grid and list)."
								   FontStyle="Italic" FontSize="11" Foreground="#666666"
								   VerticalAlignment="Center" Margin="8,0,0,0"/>
					</StackPanel>

					<StackPanel Orientation="Horizontal" Spacing="10" VerticalAlignment="Center">
						<TextBlock Text="Recent Archives Limit:" VerticalAlignment="Center" Foreground="#CCCCCC" Width="160"/>
						<ComboBox SelectedIndex="{Binding SelectedMaxRecentCombinationsIndex}" Width="120" Height="28">
							<ComboBoxItem Content="4"/>
							<ComboBoxItem Content="6"/>
							<ComboBoxItem Content="8"/>
							<ComboBoxItem Content="10"/>
							<ComboBoxItem Content="16"/>
							<ComboBoxItem Content="20"/>
						</ComboBox>
						<TextBlock Text="Maximum number of recent combinations remembered on the Home screen."
								   FontStyle="Italic" FontSize="11" Foreground="#666666"
								   VerticalAlignment="Center" Margin="8,0,0,0"/>
					</StackPanel>

					<StackPanel Orientation="Horizontal" Spacing="10" VerticalAlignment="Center">
						<TextBlock Text="Undo/Redo Buffer Size:" VerticalAlignment="Center" Foreground="#CCCCCC" Width="160"/>
						<ComboBox SelectedIndex="{Binding SelectedUndoLimitIndex}" Width="120" Height="28">
							<ComboBoxItem Content="5"/>
							<ComboBoxItem Content="10"/>
							<ComboBoxItem Content="15"/>
							<ComboBoxItem Content="20"/>
						</ComboBox>
						<TextBlock Text="Maximum number of undo actions remembered in editing panels."
								   FontStyle="Italic" FontSize="11" Foreground="#666666"
								   VerticalAlignment="Center" Margin="8,0,0,0"/>
					</StackPanel>

					<StackPanel Orientation="Horizontal" Spacing="10" VerticalAlignment="Center">
						<TextBlock Text="Allow Unknown Signatures:" VerticalAlignment="Center" Foreground="#CCCCCC" Width="160"/>
						<CheckBox IsChecked="{Binding AllowUnknownSignaturesSetting}"/>
						<TextBlock Text="Permit loading archives with unrecognized Client signatures."
								   FontStyle="Italic" FontSize="11" Foreground="#666666"
								   VerticalAlignment="Center" Margin="8,0,0,0"/>
					</StackPanel>
				</StackPanel>
			</Border>

			<!-- Sprites Panel Section -->
			<Border Background="#1E1E1E" CornerRadius="8" Padding="20" Margin="0,10,0,0">
				<StackPanel Spacing="15">
					<TextBlock Text="Sprites Panel" FontSize="18" FontWeight="SemiBold" Foreground="#FFFFFF"/>
					<StackPanel Orientation="Horizontal" Spacing="10" VerticalAlignment="Center">
						<TextBlock Text="Default Page Size:" VerticalAlignment="Center" Foreground="#CCCCCC" Width="160"/>
						<ComboBox SelectedIndex="{Binding SelectedPageSizeIndex}" Width="100">
							<ComboBoxItem Content="50"/>
							<ComboBoxItem Content="100"/>
							<ComboBoxItem Content="200"/>
							<ComboBoxItem Content="500"/>
							<ComboBoxItem Content="1000"/>
						</ComboBox>
						<TextBlock Text="Number of sprites shown per page in the viewer."
								   FontStyle="Italic" FontSize="11" Foreground="#666666"
								   VerticalAlignment="Center" Margin="8,0,0,0"/>
					</StackPanel>

					<StackPanel Orientation="Horizontal" Spacing="10" VerticalAlignment="Center">
						<TextBlock Text="Preload Sprites:" VerticalAlignment="Center" Foreground="#CCCCCC" Width="160"/>
						<CheckBox IsChecked="{Binding PreloadGraphicalAssetsSetting}"/>
						<TextBlock Text="Preload sprite pages into memory for zero lag spikes during editing/removal."
								   FontStyle="Italic" FontSize="11" Foreground="#666666"
								   VerticalAlignment="Center" Margin="8,0,0,0"/>
					</StackPanel>
				</StackPanel>
			</Border>

			<!-- Things Panel Section -->
			<Border Background="#1E1E1E" CornerRadius="8" Padding="20" Margin="0,10,0,0">
				<StackPanel Spacing="15">
					<TextBlock Text="Things Panel" FontSize="18" FontWeight="SemiBold" Foreground="#FFFFFF"/>

					<StackPanel Orientation="Horizontal" Spacing="10" VerticalAlignment="Center">
						<TextBlock Text="Client Version:" VerticalAlignment="Center" Foreground="#CCCCCC" Width="160"/>
						<ComboBox ItemsSource="{Binding AvailableVersions}"
								  SelectedItem="{Binding SelectedVersion}"
								  DisplayMemberBinding="{Binding DisplayName}"
								  Width="120" Height="28"/>
						<TextBlock Text="Affects .dat binary format parsing rules and checkbox defaults."
								   FontStyle="Italic" FontSize="11" Foreground="#666666"
								   VerticalAlignment="Center" Margin="8,0,0,0"/>
					</StackPanel>

					<StackPanel Orientation="Horizontal" Spacing="10" VerticalAlignment="Center">
						<TextBlock Text="Thing ID Offset:" VerticalAlignment="Center" Foreground="#CCCCCC" Width="160"/>
						<NumericUpDown Value="{Binding SelectedThingIdOffset}" Minimum="0" Maximum="10000" Increment="1" Width="120" Height="28" Padding="5,0"/>
						<TextBlock Text="Added to raw catalog indices when displaying IDs. Keep at 0 to match NyxAssets loader."
								   FontStyle="Italic" FontSize="11" Foreground="#666666"
								   VerticalAlignment="Center" Margin="8,0,0,0" TextWrapping="Wrap" MaxWidth="320"/>
					</StackPanel>
				</StackPanel>
			</Border>

			<!-- Animation Section -->
			<Border Background="#1E1E1E" CornerRadius="8" Padding="20" Margin="0,10,0,0">
				<StackPanel Spacing="15">
					<TextBlock Text="Animation" FontSize="18" FontWeight="SemiBold" Foreground="#FFFFFF"/>
					<TextBlock Text="Default frame duration in milliseconds. Used for preview playback and when applying default durations in the thing editor."
							   FontStyle="Italic" FontSize="11" Foreground="#666666" TextWrapping="Wrap"/>

					<StackPanel Orientation="Horizontal" Spacing="10" VerticalAlignment="Center">
						<TextBlock Text="Items:" VerticalAlignment="Center" Foreground="#CCCCCC" Width="160"/>
						<NumericUpDown Value="{Binding ItemAnimationDuration}" Minimum="0" Maximum="60000" Increment="10" Width="120" Height="28" Padding="5,0"/>
						<TextBlock Text="ms" VerticalAlignment="Center" Foreground="#888888" FontSize="11"/>
					</StackPanel>

					<StackPanel Orientation="Horizontal" Spacing="10" VerticalAlignment="Center">
						<TextBlock Text="Outfits:" VerticalAlignment="Center" Foreground="#CCCCCC" Width="160"/>
						<NumericUpDown Value="{Binding OutfitAnimationDuration}" Minimum="0" Maximum="60000" Increment="10" Width="120" Height="28" Padding="5,0"/>
						<TextBlock Text="ms" VerticalAlignment="Center" Foreground="#888888" FontSize="11"/>
					</StackPanel>

					<StackPanel Orientation="Horizontal" Spacing="10" VerticalAlignment="Center">
						<TextBlock Text="Effects:" VerticalAlignment="Center" Foreground="#CCCCCC" Width="160"/>
						<NumericUpDown Value="{Binding EffectAnimationDuration}" Minimum="0" Maximum="60000" Increment="10" Width="120" Height="28" Padding="5,0"/>
						<TextBlock Text="ms" VerticalAlignment="Center" Foreground="#888888" FontSize="11"/>
					</StackPanel>

					<StackPanel Orientation="Horizontal" Spacing="10" VerticalAlignment="Center">
						<TextBlock Text="Missiles:" VerticalAlignment="Center" Foreground="#CCCCCC" Width="160"/>
						<NumericUpDown Value="{Binding MissileAnimationDuration}" Minimum="0" Maximum="60000" Increment="10" Width="120" Height="28" Padding="5,0"/>
						<TextBlock Text="ms" VerticalAlignment="Center" Foreground="#888888" FontSize="11"/>
					</StackPanel>
				</StackPanel>
			</Border>

			<!-- Looktype Generator Section -->
			<Border Background="#1E1E1E" CornerRadius="8" Padding="20" Margin="0,10,0,0">
				<StackPanel Spacing="15">
					<TextBlock Text="Looktype Generator" FontSize="18" FontWeight="SemiBold" Foreground="#FFFFFF"/>
					<TextBlock Text="Mount rendering differs between client implementations. These options affect preview rendering only and are not exported to TFS Lua or XML."
							   FontStyle="Italic" FontSize="11" Foreground="#666666" TextWrapping="Wrap"/>

					<StackPanel Orientation="Horizontal" Spacing="10" VerticalAlignment="Center">
						<TextBlock Text="Mount alignment:" VerticalAlignment="Center" Foreground="#CCCCCC" Width="160"/>
						<ComboBox SelectedIndex="{Binding SelectedLooktypeMountAlignmentIndex}" Width="220" Height="28">
							<ComboBoxItem Content="OTClient-compatible"/>
							<ComboBoxItem Content="Independent asset displacement"/>
						</ComboBox>
					</StackPanel>

					<StackPanel Orientation="Horizontal" Spacing="10" VerticalAlignment="Center">
						<TextBlock Text="Rider correction X:" VerticalAlignment="Center" Foreground="#CCCCCC" Width="160"/>
						<NumericUpDown Value="{Binding LooktypeMountedRiderOffsetXSetting}" Minimum="-128" Maximum="128" Increment="1" FormatString="0" ParsingNumberStyle="Integer" Width="120" Height="28" Padding="5,0"/>
						<TextBlock Text="pixels (positive moves right)" VerticalAlignment="Center" Foreground="#888888" FontSize="11"/>
					</StackPanel>

					<StackPanel Orientation="Horizontal" Spacing="10" VerticalAlignment="Center">
						<TextBlock Text="Rider correction Y:" VerticalAlignment="Center" Foreground="#CCCCCC" Width="160"/>
						<NumericUpDown Value="{Binding LooktypeMountedRiderOffsetYSetting}" Minimum="-128" Maximum="128" Increment="1" FormatString="0" ParsingNumberStyle="Integer" Width="120" Height="28" Padding="5,0"/>
						<TextBlock Text="pixels (positive moves down)" VerticalAlignment="Center" Foreground="#888888" FontSize="11"/>
					</StackPanel>
				</StackPanel>
			</Border>

			<!-- Thing Editor Appearance Section -->
			<Border Background="#1E1E1E" CornerRadius="8" Padding="20" Margin="0,10,0,0">
				<StackPanel Spacing="15">
					<TextBlock Text="Thing Editor Appearance" FontSize="18" FontWeight="SemiBold" Foreground="#FFFFFF"/>
					<TextBlock Text="Grid colors use #AARRGGBB or #RRGGBB hex. Drag grid appears automatically while assigning sprites."
							   FontStyle="Italic" FontSize="11" Foreground="#666666" TextWrapping="Wrap"/>

					<TextBlock Text="Show grid" FontWeight="SemiBold" Foreground="#CCCCCC" FontSize="12"/>
					<StackPanel Orientation="Horizontal" Spacing="10" VerticalAlignment="Center">
						<TextBlock Text="Color:" VerticalAlignment="Center" Foreground="#CCCCCC" Width="160"/>
						<local:HexColorPicker HexColor="{Binding ThingEditorGridColorSetting}"/>
					</StackPanel>
					<StackPanel Orientation="Horizontal" Spacing="10" VerticalAlignment="Center">
						<TextBlock Text="Line width:" VerticalAlignment="Center" Foreground="#CCCCCC" Width="160"/>
						<NumericUpDown Value="{Binding ThingEditorGridLineWidthSetting}" Minimum="1" Maximum="4" Increment="1" Width="120" Height="28" Padding="5,0"/>
					</StackPanel>

					<TextBlock Text="Drag preview" FontWeight="SemiBold" Foreground="#CCCCCC" FontSize="12" Margin="0,8,0,0"/>
					<StackPanel Orientation="Horizontal" Spacing="10" VerticalAlignment="Center">
						<TextBlock Text="Grid color:" VerticalAlignment="Center" Foreground="#CCCCCC" Width="160"/>
						<local:HexColorPicker HexColor="{Binding ThingEditorDragGridColorSetting}"/>
					</StackPanel>
					<StackPanel Orientation="Horizontal" Spacing="10" VerticalAlignment="Center">
						<TextBlock Text="Grid line width:" VerticalAlignment="Center" Foreground="#CCCCCC" Width="160"/>
						<NumericUpDown Value="{Binding ThingEditorDragGridLineWidthSetting}" Minimum="1" Maximum="4" Increment="1" Width="120" Height="28" Padding="5,0"/>
					</StackPanel>
					<StackPanel Orientation="Horizontal" Spacing="10" VerticalAlignment="Center">
						<TextBlock Text="Tile highlight:" VerticalAlignment="Center" Foreground="#CCCCCC" Width="160"/>
						<local:HexColorPicker HexColor="{Binding ThingEditorDragHighlightColorSetting}"/>
					</StackPanel>
				</StackPanel>
			</Border>
		</StackPanel>
	</ScrollViewer>
</UserControl>

