<UserControl xmlns="https://github.com/avaloniaui"
			 xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
			 xmlns:vm="using:NyxAssetsEditor.ViewModels.Pages"
			 x:Class="NyxAssetsEditor.Views.Pages.HomeView"
			 x:DataType="vm:HomeViewModel">
	<ScrollViewer>
		<StackPanel Margin="30" Spacing="25">
			<!-- Header -->
			<StackPanel Spacing="5">
				<TextBlock Text="{Binding Title, Mode=OneWay}" FontSize="28" FontWeight="Bold" Foreground="#5E94FF"/>
				<TextBlock Text="{Binding Description, Mode=OneWay}" FontSize="14" Foreground="#888888" TextWrapping="Wrap"/>
			</StackPanel>

			<!-- Recent Archives Section -->
			<StackPanel Spacing="10">
				<TextBlock Text="Recent Archives" FontSize="18" FontWeight="SemiBold" Foreground="#FFFFFF"/>
				
				<!-- Placeholder if no recents -->
				<Border IsVisible="{Binding !RecentCombinations.Count}" Background="#1E1E1E" CornerRadius="8" Padding="20">
					<TextBlock Text="No recently opened archives. Open an archive from the Assets workspace to get started!" Foreground="#666666" FontStyle="Italic"/>
				</Border>

				<!-- List of Recents -->
				<ItemsControl ItemsSource="{Binding RecentCombinations}" IsVisible="{Binding RecentCombinations.Count}">
					<ItemsControl.ItemsPanel>
						<ItemsPanelTemplate>
							<WrapPanel Orientation="Horizontal" HorizontalAlignment="Left"/>
						</ItemsPanelTemplate>
					</ItemsControl.ItemsPanel>
					<ItemsControl.ItemTemplate>
						<DataTemplate x:DataType="vm:RecentCombinationItemViewModel">
							<Border Background="#1E1E1E" BorderThickness="1" BorderBrush="#2D2D2D" CornerRadius="8" Margin="0,0,12,12" Width="280">
								<Border.Styles>
									<Style Selector="Border:pointerover">
										<Setter Property="BorderBrush" Value="#5E94FF"/>
									</Style>
								</Border.Styles>
								<Grid ColumnDefinitions="*, Auto">
									<!-- Clickable Load Button -->
									<Button Grid.Column="0" Command="{Binding LoadCommand}" ToolTip.Tip="{Binding ToolTipText}" Background="Transparent" BorderThickness="0" CornerRadius="8,0,0,8" Padding="14,12" HorizontalAlignment="Stretch" VerticalAlignment="Stretch" HorizontalContentAlignment="Stretch">
										<Button.Styles>
											<Style Selector="Button:pointerover">
												<Setter Property="Background" Value="#252525"/>
											</Style>
										</Button.Styles>
										<Grid ColumnDefinitions="48,*">
											<!-- Icon based on type -->
											<Grid Grid.Column="0" VerticalAlignment="Center" HorizontalAlignment="Left">
												<!-- Icon for Both (DAT + SPR) -->
												<Image IsVisible="{Binding HasBoth}" Source="/Assets/Icons/home/both.png" Width="20" Height="20"/>
												<!-- Icon for Sprite only -->
												<Image IsVisible="{Binding HasSpriteOnly}" Source="/Assets/Icons/home/sprites.png" Width="20" Height="20"/>
												<!-- Icon for Things only -->
												<Image IsVisible="{Binding HasThingsOnly}" Source="/Assets/Icons/home/things.png" Width="20" Height="20"/>
											</Grid>
											
											<!-- Texts -->
											<StackPanel Grid.Column="1" Spacing="3" VerticalAlignment="Center">
												<TextBlock Text="{Binding DisplayName}" FontWeight="SemiBold" FontSize="13" Foreground="#FFFFFF" TextTrimming="CharacterEllipsis"/>
												<TextBlock Text="{Binding DetailsText}" FontSize="11" Foreground="#666666" TextTrimming="CharacterEllipsis"/>
											</StackPanel>
										</Grid>
									</Button>
									
									<!-- Remove Button (X) -->
									<Button Grid.Column="1" Command="{Binding RemoveCommand}" Width="28" Height="28" Margin="0,0,8,0" Background="Transparent" BorderThickness="0" CornerRadius="14" VerticalAlignment="Center" ToolTip.Tip="Remove from Recents">
										<Button.Styles>
											<Style Selector="Button:pointerover">
												<Setter Property="Background" Value="#33FF5E5E"/>
											</Style>
										</Button.Styles>
										<Image Source="/Assets/Icons/home/close.png" Width="10" Height="10" HorizontalAlignment="Center" VerticalAlignment="Center"/>
									</Button>
								</Grid>
							</Border>
						</DataTemplate>
					</ItemsControl.ItemTemplate>
				</ItemsControl>
			</StackPanel>

			<!-- Quick Actions Card -->
			<Border Background="#1E1E1E" CornerRadius="8" Padding="20">
				<StackPanel Spacing="10">
					<TextBlock Text="Quick Actions" FontSize="18" FontWeight="SemiBold" Foreground="#FFFFFF"/>
					<TextBlock Text="Use the top navigation bar to switch to the Assets page and load archives (.spr / .dat or .assets / .json)." Foreground="#999999" TextWrapping="Wrap"/>
				</StackPanel>
			</Border>
		</StackPanel>
	</ScrollViewer>
</UserControl>
