<Window xmlns="https://github.com/avaloniaui"
		xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
		xmlns:local="using:NyxAssetsEditor.Views.Pages"
		x:Class="NyxAssetsEditor.Views.Pages.SpritesOptimizerDialog"
		x:DataType="local:SpritesOptimizerDialogViewModel"
		Title="Sprites Optimizer"
		Width="400"
		SizeToContent="Height"
		CanResize="False"
		WindowStartupLocation="CenterOwner"
		Background="#141414"
		RequestedThemeVariant="Dark"
		ShowInTaskbar="False">

	<Border Background="#1E1E1E" BorderBrush="#333333" BorderThickness="1">
		<StackPanel Spacing="0">

			<!-- Header -->
			<Border Background="#252525" BorderBrush="#333333" BorderThickness="0,0,0,1" Padding="20,16">
				<TextBlock Text="Sprites Optimizer" FontSize="16" FontWeight="SemiBold"
						   Foreground="#F0F0F0" VerticalAlignment="Center"/>
			</Border>

			<!-- Body -->
			<Border Padding="20,18">
				<StackPanel Spacing="16">
					
					<!-- STATE 1: Error - No Linked Things File -->
					<StackPanel Spacing="12" IsVisible="{Binding !IsLinked}">
						<TextBlock Text="No Linked Things Archive Found" FontSize="14" FontWeight="SemiBold" Foreground="#FF6B6B"/>
						<TextBlock Text="Please load and link a Things (.dat/.things) archive to this Sprites Viewer first so the optimizer knows which sprites are assigned to items." TextWrapping="Wrap" Foreground="#A0A0A0" FontSize="12"/>
					</StackPanel>

					<!-- STATE 2: Configuration -->
					<StackPanel Spacing="14" IsVisible="{Binding ShowConfig}">
						<TextBlock Text="This tool scans the linked Things archive to find all unused sprites, removes them from the sprite archive, and shifts/updates references in your Things archive." TextWrapping="Wrap" Foreground="#CCCCCC" FontSize="12"/>
						
						<StackPanel Spacing="6">
							<CheckBox IsChecked="{Binding ExportRemoved, Mode=TwoWay}" Content="Export removed sprites as .png"/>
						</StackPanel>

						<StackPanel Spacing="6" IsEnabled="{Binding ExportRemoved}">
							<TextBlock Text="Export Folder Path:" Foreground="#A0A0A0" FontSize="11"/>
							<Grid ColumnDefinitions="*, Auto">
								<TextBox Grid.Column="0" Text="{Binding ExportPath, Mode=TwoWay}" PlaceholderText="Select folder..." Height="26" VerticalContentAlignment="Center" FontSize="11"/>
								<Button Grid.Column="1" Content="Browse..." Margin="6,0,0,0" Padding="8,4" FontSize="11" Click="OnBrowseFolderClick"/>
							</Grid>
						</StackPanel>
					</StackPanel>

					<!-- STATE 3: Confirmation -->
					<StackPanel Spacing="14" IsVisible="{Binding ShowConfirm}">
						<TextBlock Text="Are you sure you want to run the sprites optimizer?" FontSize="14" FontWeight="SemiBold" Foreground="#FFD700"/>
						<TextBlock Text="Warning: This operation will clear the undo/redo history for both the Sprites Viewer and the Things Viewer." TextWrapping="Wrap" Foreground="#FF6B6B" FontSize="11"/>
						
						<Border Background="#252525" Padding="12" CornerRadius="4" BorderBrush="#333333" BorderThickness="1">
							<Grid ColumnDefinitions="*, Auto" RowDefinitions="Auto, Auto, Auto">
								<TextBlock Grid.Row="0" Grid.Column="0" Text="Current Sprite Count:" Margin="0,0,0,6" Foreground="#A0A0A0" FontSize="12"/>
								<TextBlock Grid.Row="0" Grid.Column="1" Text="{Binding OldSpriteCount}" Margin="0,0,0,6" Foreground="#F0F0F0" FontWeight="SemiBold" FontSize="12"/>

								<TextBlock Grid.Row="1" Grid.Column="0" Text="Unused Sprites (to remove):" Margin="0,0,0,6" Foreground="#A0A0A0" FontSize="12"/>
								<TextBlock Grid.Row="1" Grid.Column="1" Text="{Binding UnusedCount}" Margin="0,0,0,6" Foreground="#FF6B6B" FontWeight="SemiBold" FontSize="12"/>

								<TextBlock Grid.Row="2" Grid.Column="0" Text="New Sprite Count:" Foreground="#A0A0A0" FontSize="12"/>
								<TextBlock Grid.Row="2" Grid.Column="1" Text="{Binding NewSpriteCount}" Foreground="#88CC88" FontWeight="SemiBold" FontSize="12"/>
							</Grid>
						</Border>
					</StackPanel>

					<!-- STATE 4: Completed -->
					<StackPanel Spacing="14" IsVisible="{Binding ShowCompleted}">
						<TextBlock Text="Sprites Optimization Completed!" FontSize="14" FontWeight="SemiBold" Foreground="#88CC88"/>
						
						<Border Background="#252525" Padding="12" CornerRadius="4" BorderBrush="#333333" BorderThickness="1">
							<Grid ColumnDefinitions="*, Auto" RowDefinitions="Auto, Auto, Auto">
								<TextBlock Grid.Row="0" Grid.Column="0" Text="Old Sprite Count:" Margin="0,0,0,6" Foreground="#A0A0A0" FontSize="12"/>
								<TextBlock Grid.Row="0" Grid.Column="1" Text="{Binding OldSpriteCount}" Margin="0,0,0,6" Foreground="#F0F0F0" FontSize="12"/>

								<TextBlock Grid.Row="1" Grid.Column="0" Text="Removed Sprites:" Margin="0,0,0,6" Foreground="#A0A0A0" FontSize="12"/>
								<TextBlock Grid.Row="1" Grid.Column="1" Text="{Binding RemovedCount}" Margin="0,0,0,6" Foreground="#FF6B6B" FontWeight="SemiBold" FontSize="12"/>

								<TextBlock Grid.Row="2" Grid.Column="0" Text="New Sprite Count:" Foreground="#A0A0A0" FontSize="12"/>
								<TextBlock Grid.Row="2" Grid.Column="1" Text="{Binding NewSpriteCount}" Foreground="#88CC88" FontWeight="SemiBold" FontSize="12"/>
							</Grid>
						</Border>
						
						<TextBlock Text="{Binding ExportMessage}" TextWrapping="Wrap" Foreground="#A0A0A0" FontSize="11" IsVisible="{Binding ExportRemoved}"/>
					</StackPanel>

				</StackPanel>
			</Border>

			<!-- Footer Buttons -->
			<Border Padding="20,0,20,20">
				<Grid ColumnDefinitions="*, Auto, Auto" HorizontalAlignment="Stretch">
					<Border Grid.Column="0"/>

					<!-- STATE 1 & STATE 4 Buttons -->
					<Button Grid.Column="1" Content="Close" Padding="20,8" CornerRadius="4" IsVisible="{Binding ShowCloseOnly}" Click="OnCloseClick"/>

					<!-- STATE 2 Buttons -->
					<StackPanel Grid.Column="1" Grid.ColumnSpan="2" Orientation="Horizontal" Spacing="8" IsVisible="{Binding ShowConfigButtons}">
						<Button Content="Next" Padding="20,8" Background="#FF6B6B" BorderBrush="#FF5252" BorderThickness="1" Foreground="#FFFFFF" CornerRadius="4" Click="OnNextClick"/>
						<Button Content="Cancel" Padding="20,8" Background="#2A2A2A" BorderBrush="#444444" BorderThickness="1" Foreground="#AAAAAA" CornerRadius="4" Click="OnCancelClick"/>
					</StackPanel>

					<!-- STATE 3 Buttons -->
					<StackPanel Grid.Column="1" Grid.ColumnSpan="2" Orientation="Horizontal" Spacing="8" IsVisible="{Binding ShowConfirmButtons}">
						<Button Content="Optimize" Padding="20,8" Background="#88CC88" BorderBrush="#3A6A3A" BorderThickness="1" Foreground="#1A3A1A" CornerRadius="4" Click="OnOptimizeClick"/>
						<Button Content="Back" Padding="20,8" Background="#2A2A2A" BorderBrush="#444444" BorderThickness="1" Foreground="#AAAAAA" CornerRadius="4" Click="OnBackClick"/>
					</StackPanel>
				</Grid>
			</Border>

		</StackPanel>
	</Border>
</Window>
