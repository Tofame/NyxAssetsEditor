<Window xmlns="https://github.com/avaloniaui"
		xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
		x:Class="NyxAssetsEditor.Views.Pages.ResizeCanvasDialog"
		Title="Resize Canvas"
		Width="320"
		SizeToContent="Height"
		CanResize="False"
		WindowStartupLocation="CenterOwner"
		Background="#141414"
		RequestedThemeVariant="Dark"
		ShowInTaskbar="False">

	<Border Background="#1E1E1E" BorderBrush="#333333" BorderThickness="1">
		<StackPanel Spacing="0">

			<!-- Header -->
			<Border Background="#252525" BorderBrush="#333333" BorderThickness="0,0,0,1" Padding="15,12">
				<StackPanel Orientation="Horizontal" Spacing="10" VerticalAlignment="Center">
					<TextBlock Text="Resize Canvas" FontSize="14" FontWeight="SemiBold"
							   Foreground="#F0F0F0" VerticalAlignment="Center"/>
				</StackPanel>
			</Border>

			<!-- Body -->
			<Border Padding="20,15">
				<StackPanel Spacing="12">
					<Grid RowDefinitions="Auto, Auto" ColumnDefinitions="*, *">
						<StackPanel Grid.Row="0" Grid.Column="0" Margin="0,0,10,0" Spacing="4">
							<TextBlock Text="Width (pixels)" Foreground="#A0A0A0" FontSize="11"/>
							<NumericUpDown Name="WidthInput" Minimum="1" Maximum="512" FormatString="0" ParsingNumberStyle="Integer" Height="26" Value="32"/>
						</StackPanel>

						<StackPanel Grid.Row="0" Grid.Column="1" Margin="10,0,0,0" Spacing="4">
							<TextBlock Text="Height (pixels)" Foreground="#A0A0A0" FontSize="11"/>
							<NumericUpDown Name="HeightInput" Minimum="1" Maximum="512" FormatString="0" ParsingNumberStyle="Integer" Height="26" Value="32"/>
						</StackPanel>
					</Grid>
				</StackPanel>
			</Border>

			<!-- Buttons -->
			<Border Padding="20,8,20,15">
				<Grid ColumnDefinitions="*, Auto, Auto" HorizontalAlignment="Stretch">
					<Border Grid.Column="0"/>
					
					<Button Grid.Column="1" Name="ConfirmButton"
							Content="Resize"
							Padding="14,6" Margin="0,0,6,0"
							Background="#1A3A1A" BorderBrush="#3A6A3A" BorderThickness="1"
							Foreground="#88CC88" FontSize="12" CornerRadius="4"
							Click="OnConfirmClick"/>

					<Button Grid.Column="2" Name="CancelButton"
							Content="Cancel"
							Padding="14,6"
							Background="#2A2A2A" BorderBrush="#444444" BorderThickness="1"
							Foreground="#AAAAAA" FontSize="12" CornerRadius="4"
							Click="OnCancelClick"/>
				</Grid>
			</Border>

		</StackPanel>
	</Border>
</Window>
