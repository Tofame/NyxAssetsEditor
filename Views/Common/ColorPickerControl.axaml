<UserControl xmlns="https://github.com/avaloniaui"
			xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
			xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
			xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
			mc:Ignorable="d" d:DesignWidth="250" d:DesignHeight="180"
			x:Class="NyxAssetsEditor.Views.Common.ColorPickerControl"
			x:Name="Root">

	<StackPanel Spacing="6">
		<!-- R Slider -->
		<Grid ColumnDefinitions="30, *, 30">
			<TextBlock Grid.Column="0" Text="R" Foreground="#FF5555" VerticalAlignment="Center" FontSize="11"/>
			<Slider Grid.Column="1" Minimum="0" Maximum="255" Value="{Binding ColorR, ElementName=Root}" IsSnapToTickEnabled="True" TickFrequency="1"/>
			<TextBlock Grid.Column="2" Text="{Binding ColorR, ElementName=Root}" Foreground="#FFFFFF" VerticalAlignment="Center" HorizontalAlignment="Right" FontSize="10"/>
		</Grid>
		<!-- G Slider -->
		<Grid ColumnDefinitions="30, *, 30">
			<TextBlock Grid.Column="0" Text="G" Foreground="#55FF55" VerticalAlignment="Center" FontSize="11"/>
			<Slider Grid.Column="1" Minimum="0" Maximum="255" Value="{Binding ColorG, ElementName=Root}" IsSnapToTickEnabled="True" TickFrequency="1"/>
			<TextBlock Grid.Column="2" Text="{Binding ColorG, ElementName=Root}" Foreground="#FFFFFF" VerticalAlignment="Center" HorizontalAlignment="Right" FontSize="10"/>
		</Grid>
		<!-- B Slider -->
		<Grid ColumnDefinitions="30, *, 30">
			<TextBlock Grid.Column="0" Text="B" Foreground="#5555FF" VerticalAlignment="Center" FontSize="11"/>
			<Slider Grid.Column="1" Minimum="0" Maximum="255" Value="{Binding ColorB, ElementName=Root}" IsSnapToTickEnabled="True" TickFrequency="1"/>
			<TextBlock Grid.Column="2" Text="{Binding ColorB, ElementName=Root}" Foreground="#FFFFFF" VerticalAlignment="Center" HorizontalAlignment="Right" FontSize="10"/>
		</Grid>
		<!-- Color Preview & Hex Display -->
		<Grid ColumnDefinitions="50, *">
			<Border Grid.Column="0" Height="26" CornerRadius="4" BorderBrush="#444444" BorderThickness="1">
				<Border.Background>
					<SolidColorBrush Color="{Binding SelectedColor, ElementName=Root}"/>
				</Border.Background>
			</Border>
			<TextBox Grid.Column="1" Text="{Binding SelectedColor, ElementName=Root, Mode=OneWay}" IsReadOnly="True" Margin="5,0,0,0" VerticalAlignment="Center" FontSize="10"/>
		</Grid>
	</StackPanel>
</UserControl>
