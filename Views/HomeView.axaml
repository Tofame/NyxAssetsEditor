<UserControl xmlns="https://github.com/avaloniaui"
			 xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
			 xmlns:vm="using:NyxAssetsEditor.ViewModels"
			 x:Class="NyxAssetsEditor.Views.HomeView"
			 x:DataType="vm:HomeViewModel">
	<StackPanel Margin="30" Spacing="15">
		<TextBlock Text="{Binding Title}" FontSize="28" FontWeight="Bold" Foreground="#5E94FF"/>
		<TextBlock Text="{Binding Description}" FontSize="16" Foreground="#CCCCCC" TextWrapping="Wrap"/>
		
		<Border Background="#1E1E1E" CornerRadius="8" Padding="20" Margin="0,20,0,0">
			<StackPanel Spacing="10">
				<TextBlock Text="Quick Actions" FontSize="18" FontWeight="SemiBold" Foreground="#FFFFFF"/>
				<TextBlock Text="Use the top navigation bar to open and load Nyx Sprite Archives (.spr) or Asset Archives (.assets)." Foreground="#999999" TextWrapping="Wrap"/>
			</StackPanel>
		</Border>
	</StackPanel>
</UserControl>
