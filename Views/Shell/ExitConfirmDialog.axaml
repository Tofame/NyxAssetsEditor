<Window xmlns="https://github.com/avaloniaui"
		xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
		x:Class="NyxAssetsEditor.Views.Shell.ExitConfirmDialog"
		Title="Unsaved Changes"
		Width="420"
		SizeToContent="Height"
		CanResize="False"
		WindowStartupLocation="CenterOwner"
		Background="#141414"
		RequestedThemeVariant="Dark"
		ShowInTaskbar="False">

	<Border Background="#1E1E1E" BorderBrush="#333333" BorderThickness="1">
		<StackPanel Spacing="0">

			<!-- Header -->
			<Border Background="#252525" BorderBrush="#333333" BorderThickness="0,0,0,1" Padding="20,16">
				<StackPanel Orientation="Horizontal" Spacing="12" VerticalAlignment="Center">
					<Border Width="32" Height="32" CornerRadius="16" Background="#332B1A">
						<Path Data="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm1 15h-2v-2h2v2zm0-4h-2V7h2v6z"
							  Fill="#E8A923" Width="18" Height="18"
							  HorizontalAlignment="Center" VerticalAlignment="Center"
							  Stretch="Uniform"/>
					</Border>
					<TextBlock Text="Unsaved Changes" FontSize="15" FontWeight="SemiBold"
							   Foreground="#F0F0F0" VerticalAlignment="Center"/>
				</StackPanel>
			</Border>

			<!-- Body -->
			<Border Padding="20,18,20,8">
			<StackPanel Spacing="10">
				<TextBlock Text="You have unsaved changes. Would you like to compile them before exiting?"
						   Foreground="#CCCCCC" FontSize="13" TextWrapping="Wrap"/>

				<!-- Change summary -->
				<Border Name="SummaryBorder"
						Background="#1A2A1A" BorderBrush="#2D4D2D" BorderThickness="1"
						CornerRadius="5" Padding="12,8">
					<TextBlock Name="SummaryText"
							   Foreground="#88CC88" FontSize="11"
							   FontFamily="Consolas,Courier New,monospace"
							   TextWrapping="Wrap"/>
				</Border>
			</StackPanel>
			</Border>

			<!-- Buttons -->
			<Border Padding="20,8,20,20">
				<Grid ColumnDefinitions="*, Auto, Auto, Auto" HorizontalAlignment="Stretch">
					<TextBlock Grid.Column="0" Text="Changes will be lost if you choose No."
							   Foreground="#555555" FontSize="10" VerticalAlignment="Center"/>

					<Button Grid.Column="1" Name="YesButton"
							Content="Yes, Compile"
							Padding="14,6" Margin="0,0,6,0"
							Background="#1A3A1A" BorderBrush="#3A6A3A" BorderThickness="1"
							Foreground="#88CC88" FontSize="12" CornerRadius="4"
							Click="OnYesClick"/>

					<Button Grid.Column="2" Name="NoButton"
							Content="No, Exit"
							Padding="14,6" Margin="0,0,6,0"
							Background="#3A1A1A" BorderBrush="#6A2A2A" BorderThickness="1"
							Foreground="#CC7777" FontSize="12" CornerRadius="4"
							Click="OnNoClick"/>

					<Button Grid.Column="3" Name="CancelButton"
							Content="Cancel"
							Padding="14,6"
							Background="#2A2A2A" BorderBrush="#444444" BorderThickness="1"
							Foreground="#AAAAAA" FontSize="12" CornerRadius="4"
							Click="OnCancelClick"/>
				</Grid>
			</Border>

		</StackPanel>
	</Border>
</Window>
