<Window xmlns="https://github.com/avaloniaui"
		xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
		x:Class="NyxAssetsEditor.Views.Shell.SpritesCloseDialog"
		Title="Sprites Viewer In Use"
		Width="440"
		SizeToContent="Height"
		CanResize="False"
		WindowStartupLocation="CenterOwner"
		Background="#141414"
		RequestedThemeVariant="Dark"
		ShowInTaskbar="False">

	<Border Background="#1E1E1E" BorderBrush="#333333" BorderThickness="1">
		<StackPanel Spacing="0">

			<!-- Header -->
			<Border Background="#252525" BorderBrush="#333333" BorderThickness="0,0,0,1" Padding="20,16">
				<StackPanel Orientation="Horizontal" Spacing="12" VerticalAlignment="Center">
					<Border Width="32" Height="32" CornerRadius="16" Background="#332B1A">
						<Image Source="/Assets/Icons/state/warning.png" Width="18" Height="18"/>
					</Border>
					<TextBlock Text="Sprites Viewer In Use" FontSize="15" FontWeight="SemiBold"
							   Foreground="#F0F0F0" VerticalAlignment="Center"/>
				</StackPanel>
			</Border>

			<!-- Body -->
			<Border Padding="20,18,20,8">
			<StackPanel Spacing="12">
				<TextBlock Name="InstructionText" Text="This Sprites Viewer cannot be closed because the following Things Viewer(s) are currently linked to and using it:"
						   Foreground="#CCCCCC" FontSize="13" TextWrapping="Wrap"/>

				<!-- List of connected things viewers -->
				<Border Background="#1B2430" BorderBrush="#2A3D54" BorderThickness="1"
						CornerRadius="5" Padding="12,8">
					<TextBlock Name="SummaryText"
							   Foreground="#7FADDE" FontSize="12"
							   FontFamily="Consolas,Courier New,monospace"
							   TextWrapping="Wrap"/>
				</Border>

				<TextBlock Name="QuestionText" Text="Would you like to close these Things Viewer(s) as well?"
						   Foreground="#AAAAAA" FontSize="12" TextWrapping="Wrap"/>
			</StackPanel>
			</Border>

			<!-- Buttons -->
			<Border Padding="20,12,20,20">
				<Grid ColumnDefinitions="*, Auto, Auto" HorizontalAlignment="Stretch">
					<Border Grid.Column="0"/>

					<Button Grid.Column="1" Name="CloseBothButton"
							Content="Close Both"
							Padding="14,6" Margin="0,0,8,0"
							Background="#3A1A1A" BorderBrush="#6A2A2A" BorderThickness="1"
							Foreground="#CC7777" FontSize="12" CornerRadius="4"
							Click="OnCloseBothClick"/>

					<Button Grid.Column="2" Name="CancelButton"
							Content="Cancel"
							Padding="14,6"
							Background="#2A2A2A" BorderBrush="#444444" BorderThickness="1"
							Foreground="#AAAAAA" FontSize="12" CornerRadius="4"
							Click="OnCancelClick"/>
				</Grid>
			</Border>

		</StackPanel>
	</Border>
</Window>
